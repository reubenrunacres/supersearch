        max-width: 250px;\n   121→        }\n   122→\n   123→        .tooltip-row {\n   124→            display: flex;\n   125→            justify-content: space-between;\n   126→            margin-bottom: 5px;\n   127→        }\n   128→\n   129→        .tooltip-label {\n   130→            color: #8b94b0;\n   131→            margin-right: 10px;\n   132→        }\n   133→\n   134→        .tooltip-value {\n   135→            color: #ffffff;\n   136→            font-weight: 600;\n   137→        }\n   138→\n   139→        #chart svg {\n   140→            background: #0a0e1a;\n   141→            border-radius: 8px;\n   142→        }\n   143→\n   144→        .axis-label {\n   145→            font-size: 14px;\n   146→            fill: #8b94b0;\n   147→        }\n   148→\n   149→        .loading {\n   150→            text-align: center;\n   151→            padding: 100px 20px;\n   152→            color: #8b94b0;\n   153→        }\n   154→\n   155→        .spinner {\n   156→            border: 3px solid #141824;\n   157→            border-top: 3px solid #667eea;\n   158→            border-radius: 50%;\n   159→            width: 40px;\n   160→            height: 40px;\n   161→            animation: spin 1s linear infinite;\n   162→            margin: 20px auto;\n   163→        }\n   164→\n   165→        @keyframes spin {\n   166→            0% { transform: rotate(0deg); }\n   167→            100% { transform: rotate(360deg); }\n   168→        }\n   169→\n   170→        .insight {\n   171→            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);\n   172→            border-left: 4px solid #667eea;\n   173→            padding: 20px;\n   174→            border-radius: 8px;\n   175→            margin-top: 30px;\n   176→        }\n   177→\n   178→        .insight h3 {\n   179→            color: #667eea;\n   180→            margin-bottom: 10px;\n   181→        }\n   182→\n   183→        .insight p {\n   184→            color: #c2c9d6;\n   185→            font-size: 0.95rem;\n   186→            line-height: 1.7;\n   187→        }\n   188→\n   189→        .how-to {\n   190→            background: #141824;\n   191→            border-radius: 12px;\n   192→            padding: 25px;\n   193→            margin-top: 30px;\n   194→        }\n   195→\n   196→        .how-to h3 {\n   197→            color: #667eea;\n   198→            margin-bottom: 15px;\n   199→        }\n   200→\n   201→        .how-to ul {\n   202→            list-style: none;\n   203→            padding: 0;\n   204→        }\n   205→\n   206→        .how-to li {\n   207→            color: #c2c9d6;\n   208→            font-size: 0.95rem;\n   209→            margin-bottom: 12px;\n   210→            padding-left: 25px;\n   211→            position: relative;\n   212→        }\n   213→\n   214→        .how-to li:before {\n   215→            content: \"→\";\n   216→            position: absolute;\n   217→            left: 0;\n   218→            color: #667eea;\n   219→        }\n   220→\n   221→        footer {\n   222→            text-align: center;\n   223→            margin-top: 60px;\n   224→            padding: 30px 0;\n   225→            color: #8b94b0;\n   226→            font-size: 0.9rem;\n   227→            border-top: 1px solid #1e2538;\n   228→        }\n   229→\n   230→        footer a {\n   231→            color: #667eea;\n   232→            text-decoration: none;\n   233→        }\n   234→\n   235→        footer a:hover {\n   236→            text-decoration: underline;\n   237→        }\n   238→    </style>\n   239→</head>\n   240→<body>\n   241→    <div class=\"container\">\n   242→        <header>\n   243→            <h1>SuperSearch</h1>\n   244→            <p class=\"subtitle\">Superconductor Composition Explorer</p>\n   245→        </header>\n   246→\n   247→        <div class=\"content\">\n   248→            <div class=\"viz-container\">\n   249→                <div id=\"chart\"></div>\n   250→            </div>\n   251→            \n   252→            <div class=\"sidebar\">\n   253→                <h3>Dataset</h3>\n   254→                <div class=\"stat\">\n   255→                    <div class=\"stat-label\">Materials Analyzed</div>\n   256→                    <div class=\"stat-value\" id=\"total-materials\">-</div>\n   257→                </div>\n   258→                <div class=\"stat\">\n   259→                    <div class=\"stat-label\">Composition Families</div>\n   260→                    <div class=\"stat-value\" id=\"n-clusters\">-</div>\n   261→                </div>\n   262→                <div class=\"stat\">\n   263→                    <div class=\"stat-label\">Tc Range</div>\n   264→                    <div class=\"stat-value\" id=\"tc-range\">-</div>\n   265→                </div>\n   266→\n   267→                <div class=\"legend\">\n   268→                    <h3>Legend</h3>\n   269→                    <div class=\"legend-item\">\n   270→                        <div class=\"legend-color\" style=\"background: linear-gradient(to right, #3b82f6, #8b5cf6, #ec4899);\"></div>\n   271→                        <span>Critical Temperature (K)</span>\n   272→                    </div>\n   273→                    <div class=\"legend-item\">\n   274→                        <div class=\"legend-color\" style=\"background: rgba(239, 68, 68, 0.3); border: 2px solid #ef4444;\"></div>\n   275→                        <span>Under-explored regions</span>\n   276→                    </div>\n   277→                </div>\n   278→            </div>\n   279→        </div>\n   280→\n   281→        <div class=\"insight\">\n   282→            <h3>Key Insight</h3>\n   283→            <p id=\"insight-text\">Loading analysis...</p>\n   284→        </div>\n   285→\n   286→        <div class=\"how-to\">\n   287→            <h3>How to Read This</h3>\n   288→            <ul>\n   289→                <li><strong>Each dot</strong> represents one known superconducting material</li>\n   290→                <li><strong>X & Y axes</strong> represent composition space (PCA of elemental properties like atomic mass, radius, valence)</li>\n   291→                <li><strong>Color gradient</strong> shows critical temperature: Blue (low Tc) → Purple → Pink (high Tc)</li>\n   292→                <li><strong>Red-outlined regions</strong> are statistically under-explored areas adjacent to known superconductors</li>\n   293→                <li><strong>Hover over dots</strong> to see material properties</li>\n   294→                <li><strong>Clusters</strong> represent composition families with similar elemental characteristics</li>\n   295→            </ul>\n   296→        </div>\n   297→\n   298→        <footer>\n   299→            <p>Built to demonstrate understanding of Periodic Labs' superconductor research mission</p>\n   300→            <p style=\"margin-top: 10px;\">Data: UCI Superconductivity Database (21,263 materials) | Analysis: PCA + DBSCAN | Visualization: D3.js</p>\n   301→        </footer>\n   302→    </div>\n   303→\n   304→    <div class=\"tooltip\" id=\"tooltip\"></div>\n   305→\n   306→    <script>\n   307→        // Load and visualize data\n   308→        fetch('../data/analysis_results.json')\n   309→            .then(response => response.json())\n   310→            .then(data => {\n   311→                renderVisualization(data);\n   312→                updateStats(data.metadata);\n   313→                updateInsight(data);\n   314→            })\n   315→            .catch(error => {\n   316→                console.error('Error loading data:', error);\n   317→                document.getElementById('chart').innerHTML = '<div class=\"loading\">Error loading data</div>';\n   318→            });\n   319→\n   320→        function renderVisualization(data) {\n   321→            const margin = {top: 40, right: 40, bottom: 60, left: 60};\n   322→            const width = 800 - margin.left - margin.right;\n   323→            const height = 600 - margin.top - margin.bottom;\n   324→\n   325→            // Create SVG\n   326→            const svg = d3.select('#chart')\n   327→                .append('svg')\n   328→                .attr('width', width + margin.left + margin.right)\n   329→                .attr('height', height + margin.top + margin.bottom)\n   330→                .append('g')\n   331→                .attr('transform', `translate(${margin.left},${margin.top})`);\n   332→\n   333→            // Scales\n   334→            const xExtent = d3.extent(data.materials, d => d.x);\n   335→            const yExtent = d3.extent(data.materials, d => d.y);\n   336→            \n   337→            const xScale = d3.scaleLinear()\n   338→                .domain([xExtent[0] * 1.1, xExtent[1] * 1.1])\n   339→                .range([0, width]);\n   340→\n   341→            const yScale = d3.scaleLinear()\n   342→                .domain([yExtent[0] * 1.1, yExtent[1] * 1.1])\n   343→                .range([height, 0]);\n   344→\n   345→            // Color scale for Tc\n   346→            const colorScale = d3.scaleSequential()\n   347→                .domain([0, d3.max(data.materials, d => d.tc)])\n   348→                .interpolator(d3.interpolateRgb('#3b82f6', '#ec4899'));\n   349→\n   350→            // Draw sparse regions first (background)\n   351→            svg.selectAll('.sparse-region')\n   352→                .data(data.sparse_regions)\n   353→                .enter()\n   354→                .append('circle')\n   355→                .attr('class', 'sparse-region')\n   356→                .attr('cx', d => xScale(d.x))\n   357→                .attr('cy', d => yScale(d.y))\n   358→                .attr('r', 30)\n   359→                .attr('fill', 'rgba(239, 68, 68, 0.15)')\n   360→                .attr('stroke', '#ef4444')\n   361→                .attr('stroke-width', 1.5)\n   362→                .attr('stroke-dasharray', '4,4');\n   363→\n   364→            // Draw materials as dots\n   365→            const tooltip = d3.select('#tooltip');\n   366→\n   367→            svg.selectAll('.material')\n   368→                .data(data.materials)\n   369→                .enter()\n   370→                .append('circle')\n   371→                .attr('class', 'material')\n   372→                .attr('cx', d => xScale(d.x))\n   373→                .attr('cy', d => yScale(d.y))\n   374→                .attr('r', 3.5)\n   375→                .attr('fill', d => colorScale(d.tc))\n   376→                .attr('opacity', 0.7)\n   377→                .attr('stroke', '#ffffff')\n   378→                .attr('stroke-width', 0.5)\n   379→                .on('mouseover', function(event, d) {\n   380→                    d3.select(this)\n   381→                        .attr('r', 6)\n   382→                        .attr('opacity', 1)\n   383→                        .attr('stroke-width', 2);\n   384→                    \n   385→                    tooltip\n   386→                        .style('opacity', 1)\n   387→                        .html(`\n   388→                            <div class=\"tooltip-row\">\n   389→                                <span class=\"tooltip-label\">Tc:</span>\n   390→                                <span class=\"tooltip-value\">${d.tc.toFixed(1)}K</span>\n   391→                            </div>\n   392→                            <div class=\"tooltip-row\">\n   393→                                <span class=\"tooltip-label\">Atomic Mass:</span>\n   394→                                <span class=\"tooltip-value\">${d.atomic_mass.toFixed(1)}</span>\n   395→                            </div>\n   396→                            <div class=\"tooltip-row\">\n   397→                                <span class=\"tooltip-label\">Atomic Radius:</span>\n   398→                                <span class=\"tooltip-value\">${d.atomic_radius.toFixed(2)}</span>\n   399→                            </div>\n   400→                            <div class=\"tooltip-row\">\n   401→                                <span class=\"tooltip-label\">Valence:</span>\n   402→                                <span class=\"tooltip-value\">${d.valence.toFixed(2)}</span>\n   403→                            </div>\n   404→                        `)\n   405→                        .style('left', (event.pageX + 15) + 'px')\n   406→                        .style('top', (event.pageY - 15) + 'px');\n   407→                })\n   408→                .on('mouseout', function() {\n   409→                    d3.select(this)\n   410→                        .attr('r', 3.5)\n   411→                        .attr('opacity', 0.7)\n   412→                        .attr('stroke-width', 0.5);\n   413→                    tooltip.style('opacity', 0);\n   414→                });\n   415→\n   416→            // Axes\n   417→            const xAxis = d3.axisBottom(xScale).ticks(8);\n   418→            const yAxis = d3.axisLeft(yScale).ticks(8);\n   419→\n   420→            svg.append('g')\n   421→                .attr('transform', `translate(0,${height})`)\n   422→                .call(xAxis)\n   423→                .attr('color', '#8b94b0');\n   424→\n   425→            svg.append('g')\n   426→                .call(yAxis)\n   427→                .attr('color', '#8b94b0');\n   428→\n   429→            // Axis labels\n   430→            svg.append('text')\n   431→                .attr('class', 'axis-label')\n   432→                .attr('x', width / 2)\n   433→                .attr('y', height + 45)\n   434→                .attr('text-anchor', 'middle')\n   435→                .text('Composition Space (PC1)');\n   436→\n   437→            svg.append('text')\n   438→                .attr('class', 'axis-label')\n   439→                .attr('transform', 'rotate(-90)')\n   440→                .attr('x', -height / 2)\n   441→                .attr('y', -45)\n   442→                .attr('text-anchor', 'middle')\n   443→                .text('Composition Space (PC2)');\n   444→\n   445→            // Title\n   446→            svg.append('text')\n   447→                .attr('x', width / 2)\n   448→                .attr('y', -15)\n   449→                .attr('text-anchor', 'middle')\n   450→                .attr('font-size', '18px')\n   451→                .attr('font-weight', '600')\n   452→                .attr('fill', '#ffffff')\n   453→                .text('Superconductor Landscape');\n   454→        }\n   455→\n   456→        function updateStats(metadata) {\n   457→            document.getElementById('total-materials').textContent = \n   458→                metadata.total_materials.toLocaleString();\n   459→            document.getElementById('n-clusters').textContent = \n   460→                metadata.n_clusters;\n   461→            document.getElementById('tc-range').textContent = \n   462→                `${metadata.tc_range.min.toFixed(0)}-${metadata.tc_range.max.toFixed(0)}K`;\n   463→        }\n   464→\n   465→        function updateInsight(data) {\n   466→            const highTcThreshold = 50; // K\n   467→            const highTcMaterials = data.materials.filter(m => m.tc > highTcThreshold).length;\n   468→            const veryHighTcMaterials = data.materials.filter(m => m.tc > 100).length;\n   469→            const sparseRegions = data.sparse_regions.length;\n   470→            const avgTc = data.metadata.tc_range.mean.toFixed(1);\n   471→            \n   472→            const text = `Analysis of ${data.metadata.total_materials.toLocaleString()} known superconductors reveals ${sparseRegions} statistically under-explored regions in composition space. ` +\n   473→                `These sparse regions are adjacent to existing superconductors but have minimal experimental coverage—representing potential opportunities for discovery. ` +\n   474→                `Current dataset contains ${highTcMaterials} materials with Tc > ${highTcThreshold}K (including ${veryHighTcMaterials} above 100K), with an average Tc of ${avgTc}K. ` +\n   475→                `The highlighted regions could be strategic targets for Periodic Labs' AI-driven experimental approach, potentially accelerating the discovery of novel high-temperature superconductors.`;\n   476→            \n   477→            document.getElementById('insight-text').textContent = text;\n   478→        }\n   479→    </script>\n   480→</body>\n   481→</html>\n   482→"}]},"parent_tool_use_id":null,"session_id":"df77d6ed-acd7-4370-ab29-6b857b89c4cf","uuid":"c704d8b4-6afc-4085-b1a7-a8a86c68aaa0","tool_use_result":{"type":"text","file":{"filePath":"/Users/03-mac-alpha/.openclaw/workspace/supersearch/web-original/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SuperSearch - Superconductor Composition Explorer</title>\n    <script src=\"https://d3js.org/d3.v7.min.js\"></script>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;\n            background: #0a0e1a;\n            color: #ffffff;\n            line-height: 1.6;\n        }\n\n        .container {\n            max-width: 1400px;\n            margin: 0 auto;\n            padding: 40px 20px;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 50px;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            background-clip: text;\n            margin-bottom: 10px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: #8b94b0;\n            font-weight: 400;\n        }\n\n        .content {\n            display: grid;\n            grid-template-columns: 1fr 300px;\n            gap: 30px;\n            margin-bottom: 40px;\n        }\n\n        .viz-container {\n            background: #141824;\n            border-radius: 12px;\n            padding: 30px;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);\n        }\n\n        .sidebar {\n            background: #141824;\n            border-radius: 12px;\n            padding: 25px;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);\n        }\n\n        .sidebar h3 {\n            font-size: 1.1rem;\n            margin-bottom: 15px;\n            color: #667eea;\n        }\n\n        .stat {\n            margin-bottom: 20px;\n        }\n\n        .stat-label {\n            font-size: 0.85rem;\n            color: #8b94b0;\n            margin-bottom: 5px;\n        }\n\n        .stat-value {\n            font-size: 1.5rem;\n            font-weight: 600;\n            color: #ffffff;\n        }\n\n        .legend {\n            margin-top: 30px;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            margin-bottom: 10px;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n            margin-right: 10px;\n        }\n\n        .tooltip {\n            position: absolute;\n            background: rgba(20, 24, 36, 0.95);\n            border: 1px solid #667eea;\n            border-radius: 8px;\n            padding: 12px;\n            font-size: 0.85rem;\n            pointer-events: none;\n            opacity: 0;\n            transition: opacity 0.2s;\n            max-width: 250px;\n        }\n\n        .tooltip-row {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 5px;\n        }\n\n        .tooltip-label {\n            color: #8b94b0;\n            margin-right: 10px;\n        }\n\n        .tooltip-value {\n            color: #ffffff;\n            font-weight: 600;\n        }\n\n        #chart svg {\n            background: #0a0e1a;\n            border-radius: 8px;\n        }\n\n        .axis-label {\n            font-size: 14px;\n            fill: #8b94b0;\n        }\n\n        .loading {\n            text-align: center;\n            padding: 100px 20px;\n            color: #8b94b0;\n        }\n\n        .spinner {\n            border: 3px solid #141824;\n            border-top: 3px solid #667eea;\n            border-radius: 50%;\n            width: 40px;\n            height: 40px;\n            animation: spin 1s linear infinite;\n            margin: 20px auto;\n        }\n\n        @keyframes spin {\n            0% { transform: rotate(0deg); }\n            100% { transform: rotate(360deg); }\n        }\n\n        .insight {\n            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);\n            border-left: 4px solid #667eea;\n            padding: 20px;\n            border-radius: 8px;\n            margin-top: 30px;\n        }\n\n        .insight h3 {\n            color: #667eea;\n            margin-bottom: 10px;\n        }\n\n        .insight p {\n            color: #c2c9d6;\n            font-size: 0.95rem;\n            line-height: 1.7;\n        }\n\n        .how-to {\n            background: #141824;\n            border-radius: 12px;\n            padding: 25px;\n            margin-top: 30px;\n        }\n\n        .how-to h3 {\n            color: #667eea;\n            margin-bottom: 15px;\n        }\n\n        .how-to ul {\n            list-style: none;\n            padding: 0;\n        }\n\n        .how-to li {\n            color: #c2c9d6;\n            font-size: 0.95rem;\n            margin-bottom: 12px;\n            padding-left: 25px;\n            position: relative;\n        }\n\n        .how-to li:before {\n            content: \"→\";\n            position: absolute;\n            left: 0;\n            color: #667eea;\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 60px;\n            padding: 30px 0;\n            color: #8b94b0;\n            font-size: 0.9rem;\n            border-top: 1px solid #1e2538;\n        }\n\n        footer a {\n            color: #667eea;\n            text-decoration: none;\n        }\n\n        footer a:hover {\n            text-decoration: underline;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>SuperSearch</h1>\n            <p class=\"subtitle\">Superconductor Composition Explorer</p>\n        </header>\n\n        <div class=\"content\">\n            <div class=\"viz-container\">\n                <div id=\"chart\"></div>\n            </div>\n            \n            <div class=\"sidebar\">\n                <h3>Dataset</h3>\n                <div class=\"stat\">\n                    <div class=\"stat-label\">Materials Analyzed</div>\n                    <div class=\"stat-value\" id=\"total-materials\">-</div>\n                </div>\n                <div class=\"stat\">\n                    <div class=\"stat-label\">Composition Families</div>\n                    <div class=\"stat-value\" id=\"n-clusters\">-</div>\n                </div>\n                <div class=\"stat\">\n                    <div class=\"stat-label\">Tc Range</div>\n                    <div class=\"stat-value\" id=\"tc-range\">-</div>\n                </div>\n\n                <div class=\"legend\">\n                    <h3>Legend</h3>\n                    <div class=\"legend-item\">\n                        <div class=\"legend-color\" style=\"background: linear-gradient(to right, #3b82f6, #8b5cf6, #ec4899);\"></div>\n                        <span>Critical Temperature (K)</span>\n                    </div>\n                    <div class=\"legend-item\">\n                        <div class=\"legend-color\" style=\"background: rgba(239, 68, 68, 0.3); border: 2px solid #ef4444;\"></div>\n                        <span>Under-explored regions</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"insight\">\n            <h3>Key Insight</h3>\n            <p id=\"insight-text\">Loading analysis...</p>\n        </div>\n\n        <div class=\"how-to\">\n            <h3>How to Read This</h3>\n            <ul>\n                <li><strong>Each dot</strong> represents one known superconducting material</li>\n                <li><strong>X & Y axes</strong> represent composition space (PCA of elemental properties like atomic mass, radius, valence)</li>\n                <li><strong>Color gradient</strong> shows critical temperature: Blue (low Tc) → Purple → Pink (high Tc)</li>\n                <li><strong>Red-outlined regions</strong> are statistically under-explored areas adjacent to known superconductors</li>\n                <li><strong>Hover over dots</strong> to see material properties</li>\n                <li><strong>Clusters</strong> represent composition families with similar elemental characteristics</li>\n            </ul>\n        </div>\n\n        <footer>\n            <p>Built to demonstrate understanding of Periodic Labs' superconductor research mission</p>\n            <p style=\"margin-top: 10px;\">Data: UCI Superconductivity Database (21,263 materials) | Analysis: PCA + DBSCAN | Visualization: D3.js</p>\n        </footer>\n    </div>\n\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n\n    <script>\n        // Load and visualize data\n        fetch('../data/analysis_results.json')\n            .then(response => response.json())\n            .then(data => {\n                renderVisualization(data);\n                updateStats(data.metadata);\n                updateInsight(data);\n            })\n            .catch(error => {\n                console.error('Error loading data:', error);\n                document.getElementById('chart').innerHTML = '<div class=\"loading\">Error loading data</div>';\n            });\n\n        function renderVisualization(data) {\n            const margin = {top: 40, right: 40, bottom: 60, left: 60};\n            const width = 800 - margin.left - margin.right;\n            const height = 600 - margin.top - margin.bottom;\n\n            // Create SVG\n            const svg = d3.select('#chart')\n                .append('svg')\n                .attr('width', width + margin.left + margin.right)\n                .attr('height', height + margin.top + margin.bottom)\n                .append('g')\n                .attr('transform', `translate(${margin.left},${margin.top})`);\n\n            // Scales\n            const xExtent = d3.extent(data.materials, d => d.x);\n            const yExtent = d3.extent(data.materials, d => d.y);\n            \n            const xScale = d3.scaleLinear()\n                .domain([xExtent[0] * 1.1, xExtent[1] * 1.1])\n                .range([0, width]);\n\n            const yScale = d3.scaleLinear()\n                .domain([yExtent[0] * 1.1, yExtent[1] * 1.1])\n                .range([height, 0]);\n\n            // Color scale for Tc\n            const colorScale = d3.scaleSequential()\n                .domain([0, d3.max(data.materials, d => d.tc)])\n                .interpolator(d3.interpolateRgb('#3b82f6', '#ec4899'));\n\n            // Draw sparse regions first (background)\n            svg.selectAll('.sparse-region')\n                .data(data.sparse_regions)\n                .enter()\n                .append('circle')\n                .attr('class', 'sparse-region')\n                .attr('cx', d => xScale(d.x))\n                .attr('cy', d => yScale(d.y))\n                .attr('r', 30)\n                .attr('fill', 'rgba(239, 68, 68, 0.15)')\n                .attr('stroke', '#ef4444')\n                .attr('stroke-width', 1.5)\n                .attr('stroke-dasharray', '4,4');\n\n            // Draw materials as dots\n            const tooltip = d3.select('#tooltip');\n\n            svg.selectAll('.material')\n                .data(data.materials)\n                .enter()\n                .append('circle')\n                .attr('class', 'material')\n                .attr('cx', d => xScale(d.x))\n                .attr('cy', d => yScale(d.y))\n                .attr('r', 3.5)\n                .attr('fill', d => colorScale(d.tc))\n                .attr('opacity', 0.7)\n                .attr('stroke', '#ffffff')\n                .attr('stroke-width', 0.5)\n                .on('mouseover', function(event, d) {\n                    d3.select(this)\n                        .attr('r', 6)\n                        .attr('opacity', 1)\n                        .attr('stroke-width', 2);\n                    \n                    tooltip\n                        .style('opacity', 1)\n                        .html(`\n                            <div class=\"tooltip-row\">\n                                <span class=\"tooltip-label\">Tc:</span>\n                                <span class=\"tooltip-value\">${d.tc.toFixed(1)}K</span>\n                            </div>\n                            <div class=\"tooltip-row\">\n                                <span class=\"tooltip-label\">Atomic Mass:</span>\n                                <span class=\"tooltip-value\">${d.atomic_mass.toFixed(1)}</span>\n                            </div>\n                            <div class=\"tooltip-row\">\n                                <span class=\"tooltip-label\">Atomic Radius:</span>\n                                <span class=\"tooltip-value\">${d.atomic_radius.toFixed(2)}</span>\n                            </div>\n                            <div class=\"tooltip-row\">\n                                <span class=\"tooltip-label\">Valence:</span>\n                                <span class=\"tooltip-value\">${d.valence.toFixed(2)}</span>\n                            </div>\n                        `)\n                        .style('left', (event.pageX + 15) + 'px')\n                        .style('top', (event.pageY - 15) + 'px');\n                })\n                .on('mouseout', function() {\n                    d3.select(this)\n                        .attr('r', 3.5)\n                        .attr('opacity', 0.7)\n                        .attr('stroke-width', 0.5);\n                    tooltip.style('opacity', 0);\n                });\n\n            // Axes\n            const xAxis = d3.axisBottom(xScale).ticks(8);\n            const yAxis = d3.axisLeft(yScale).ticks(8);\n\n            svg.append('g')\n                .attr('transform', `translate(0,${height})`)\n                .call(xAxis)\n                .attr('color', '#8b94b0');\n\n            svg.append('g')\n                .call(yAxis)\n                .attr('color', '#8b94b0');\n\n            // Axis labels\n            svg.append('text')\n                .attr('class', 'axis-label')\n                .attr('x', width / 2)\n                .attr('y', height + 45)\n                .attr('text-anchor', 'middle')\n                .text('Composition Space (PC1)');\n\n            svg.append('text')\n                .attr('class', 'axis-label')\n                .attr('transform', 'rotate(-90)')\n                .attr('x', -height / 2)\n                .attr('y', -45)\n                .attr('text-anchor', 'middle')\n                .text('Composition Space (PC2)');\n\n            // Title\n            svg.append('text')\n                .attr('x', width / 2)\n                .attr('y', -15)\n                .attr('text-anchor', 'middle')\n                .attr('font-size', '18px')\n                .attr('font-weight', '600')\n                .attr('fill', '#ffffff')\n                .text('Superconductor Landscape');\n        }\n\n        function updateStats(metadata) {\n            document.getElementById('total-materials').textContent = \n                metadata.total_materials.toLocaleString();\n            document.getElementById('n-clusters').textContent = \n                metadata.n_clusters;\n            document.getElementById('tc-range').textContent = \n                `${metadata.tc_range.min.toFixed(0)}-${metadata.tc_range.max.toFixed(0)}K`;\n        }\n\n        function updateInsight(data) {\n            const highTcThreshold = 50; // K\n            const highTcMaterials = data.materials.filter(m => m.tc > highTcThreshold).length;\n            const veryHighTcMaterials = data.materials.filter(m => m.tc > 100).length;\n            const sparseRegions = data.sparse_regions.length;\n            const avgTc = data.metadata.tc_range.mean.toFixed(1);\n            \n            const text = `Analysis of ${data.metadata.total_materials.toLocaleString()} known superconductors reveals ${sparseRegions} statistically under-explored regions in composition space. ` +\n                `These sparse regions are adjacent to existing superconductors but have minimal experimental coverage—representing potential opportunities for discovery. ` +\n                `Current dataset contains ${highTcMaterials} materials with Tc > ${highTcThreshold}K (including ${veryHighTcMaterials} above 100K), with an average Tc of ${avgTc}K. ` +\n                `The highlighted regions could be strategic targets for Periodic Labs' AI-driven experimental approach, potentially accelerating the discovery of novel high-temperature superconductors.`;\n            \n            document.getElementById('insight-text').textContent = text;\n        }\n    </script>\n</body>\n</html>\n","numLines":482,"startLine":1,"totalLines":482}}}
