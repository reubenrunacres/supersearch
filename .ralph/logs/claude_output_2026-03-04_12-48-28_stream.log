  <div class=\"legend-label\">Family C</div>\n   400→                    <div class=\"legend-count\" id=\"count-2\">0</div>\n   401→                </div>\n   402→                \n   403→                <div class=\"section-title\" style=\"margin-top: 24px;\">Critical Temperature</div>\n   404→                <div class=\"tc-gradient\"></div>\n   405→                <div class=\"tc-labels\">\n   406→                    <span>0K</span>\n   407→                    <span>93K</span>\n   408→                    <span>185K</span>\n   409→                </div>\n   410→            </div>\n   411→        </div>\n   412→\n   413→        <div id=\"loading\">\n   414→            <div class=\"loading-spinner\"></div>\n   415→            <div class=\"loading-text\">Loading 21,263 materials...</div>\n   416→        </div>\n   417→\n   418→        <div id=\"tooltip\"></div>\n   419→    </div>\n   420→\n   421→    <script>\n   422→        // Scene setup\n   423→        const scene = new THREE.Scene();\n   424→        scene.background = new THREE.Color(0x0a0e1a);\n   425→        scene.fog = new THREE.FogExp2(0x0a0e1a, 0.002);\n   426→\n   427→        const container = document.getElementById('canvas-container');\n   428→        const camera = new THREE.PerspectiveCamera(\n   429→            50,\n   430→            container.clientWidth / container.clientHeight,\n   431→            0.1,\n   432→            1000\n   433→        );\n   434→        camera.position.set(80, 60, 80);\n   435→\n   436→        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });\n   437→        renderer.setSize(container.clientWidth, container.clientHeight);\n   438→        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n   439→        container.appendChild(renderer.domElement);\n   440→\n   441→        // Orbit controls\n   442→        const controls = new THREE.OrbitControls(camera, renderer.domElement);\n   443→        controls.enableDamping = true;\n   444→        controls.dampingFactor = 0.05;\n   445→        controls.minDistance = 30;\n   446→        controls.maxDistance = 200;\n   447→        controls.maxPolarAngle = Math.PI * 0.95;\n   448→        controls.autoRotate = true;\n   449→        controls.autoRotateSpeed = 0.3;\n   450→\n   451→        // Lighting\n   452→        const ambientLight = new THREE.AmbientLight(0xffffff, 0.3);\n   453→        scene.add(ambientLight);\n   454→\n   455→        const pointLight1 = new THREE.PointLight(0x3b82f6, 2, 300);\n   456→        pointLight1.position.set(60, 60, 60);\n   457→        scene.add(pointLight1);\n   458→\n   459→        const pointLight2 = new THREE.PointLight(0xec4899, 1.5, 300);\n   460→        pointLight2.position.set(-60, -40, -60);\n   461→        scene.add(pointLight2);\n   462→\n   463→        const pointLight3 = new THREE.PointLight(0x8b5cf6, 1, 200);\n   464→        pointLight3.position.set(0, 80, 0);\n   465→        scene.add(pointLight3);\n   466→\n   467→        // Grid and axes\n   468→        const gridHelper = new THREE.GridHelper(120, 24, 0x2563eb, 0x1a1f2e);\n   469→        gridHelper.position.y = -40;\n   470→        scene.add(gridHelper);\n   471→\n   472→        const axesHelper = new THREE.AxesHelper(50);\n   473→        scene.add(axesHelper);\n   474→\n   475→        // Data structures\n   476→        let pointsMesh;\n   477→        let sparseBoxes = [];\n   478→        let materials = [];\n   479→        let clusterVisibility = [true, true, true];\n   480→        let autoRotate = true;\n   481→\n   482→        // Cluster colors\n   483→        const clusterColors = [\n   484→            new THREE.Color(0x3b82f6), // Blue\n   485→            new THREE.Color(0x8b5cf6), // Purple\n   486→            new THREE.Color(0xec4899)  // Pink\n   487→        ];\n   488→\n   489→        // Load and visualize data\n   490→        fetch('data/analysis_results.json')\n   491→            .then(response => response.json())\n   492→            .then(data => {\n   493→                materials = data.materials;\n   494→                createVisualization(data);\n   495→                document.getElementById('loading').style.display = 'none';\n   496→            })\n   497→            .catch(error => {\n   498→                console.error('Error loading data:', error);\n   499→                document.getElementById('loading').innerHTML = '<div class=\"loading-text\" style=\"color: #ef4444;\">Error loading data</div>';\n   500→            });\n   501→\n   502→        function createVisualization(data) {\n   503→            // Calculate data extents\n   504→            const xExtent = [Math.min(...data.materials.map(m => m.x)), Math.max(...data.materials.map(m => m.x))];\n   505→            const yExtent = [Math.min(...data.materials.map(m => m.y)), Math.max(...data.materials.map(m => m.y))];\n   506→            const tcExtent = [data.metadata.tc_range.min, data.metadata.tc_range.max];\n   507→            \n   508→            // Better scaling - spread across full 3D space\n   509→            const scaleX = 60;\n   510→            const scaleY = 60;\n   511→            const scaleZ = 60;\n   512→            \n   513→            const xScale = (x) => ((x - xExtent[0]) / (xExtent[1] - xExtent[0]) - 0.5) * scaleX;\n   514→            const yScale = (y) => ((y - yExtent[0]) / (yExtent[1] - yExtent[0]) - 0.5) * scaleY;\n   515→            const zScale = (tc) => ((tc - tcExtent[0]) / (tcExtent[1] - tcExtent[0]) - 0.5) * scaleZ;\n   516→\n   517→            // Create sprite texture for points (better than plain dots)\n   518→            const canvas = document.createElement('canvas');\n   519→            canvas.width = 32;\n   520→            canvas.height = 32;\n   521→            const ctx = canvas.getContext('2d');\n   522→            const gradient = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);\n   523→            gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');\n   524→            gradient.addColorStop(0.3, 'rgba(255, 255, 255, 0.8)');\n   525→            gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');\n   526→            ctx.fillStyle = gradient;\n   527→            ctx.fillRect(0, 0, 32, 32);\n   528→            const sprite = new THREE.CanvasTexture(canvas);\n   529→\n   530→            // Create points geometry\n   531→            const geometry = new THREE.BufferGeometry();\n   532→            const positions = [];\n   533→            const colors = [];\n   534→            const sizes = [];\n   535→\n   536→            // Count by cluster\n   537→            const clusterCounts = [0, 0, 0];\n   538→\n   539→            data.materials.forEach(material => {\n   540→                const x = xScale(material.x);\n   541→                const y = zScale(material.tc);\n   542→                const z = yScale(material.y);\n   543→                \n   544→                positions.push(x, y, z);\n   545→                \n   546→                // Use cluster color\n   547→                const color = clusterColors[material.cluster];\n   548→                colors.push(color.r, color.g, color.b);\n   549→                \n   550→                // Vary size by Tc (higher Tc = bigger)\n   551→                const size = 0.5 + (material.tc / tcExtent[1]) * 1.5;\n   552→                sizes.push(size);\n   553→                \n   554→                clusterCounts[material.cluster]++;\n   555→            });\n   556→\n   557→            // Update counts in legend\n   558→            document.getElementById('count-0').textContent = clusterCounts[0].toLocaleString();\n   559→            document.getElementById('count-1').textContent = clusterCounts[1].toLocaleString();\n   560→            document.getElementById('count-2').textContent = clusterCounts[2].toLocaleString();\n   561→\n   562→            geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));\n   563→            geometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));\n   564→            geometry.setAttribute('size', new THREE.Float32BufferAttribute(sizes, 1));\n   565→\n   566→            const material = new THREE.PointsMaterial({\n   567→                size: 1.2,\n   568→                vertexColors: true,\n   569→                transparent: true,\n   570→                opacity: 0.85,\n   571→                sizeAttenuation: true,\n   572→                map: sprite,\n   573→                blending: THREE.AdditiveBlending,\n   574→                depthWrite: false\n   575→            });\n   576→\n   577→            pointsMesh = new THREE.Points(geometry, material);\n   578→            scene.add(pointsMesh);\n   579→\n   580→            // Create sparse region boxes (make them VISIBLE and IMPRESSIVE)\n   581→            if (data.sparse_regions) {\n   582→                const gridSize = 1.5; // Approximate grid cell size\n   583→                \n   584→                data.sparse_regions.forEach((region, index) => {\n   585→                    const centerX = xScale(region.x);\n   586→                    const centerZ = yScale(region.y);\n   587→                    \n   588→                    // Create filled box with glow\n   589→                    const boxGeometry = new THREE.BoxGeometry(gridSize * 2, scaleZ * 0.8, gridSize * 2);\n   590→                    \n   591→                    // Filled box\n   592→                    const boxMaterial = new THREE.MeshBasicMaterial({\n   593→                        color: 0x3b82f6,\n   594→                        transparent: true,\n   595→                        opacity: 0.08,\n   596→                        side: THREE.DoubleSide\n   597→                    });\n   598→                    \n   599→                    const box = new THREE.Mesh(boxGeometry, boxMaterial);\n   600→                    box.position.set(centerX, 0, centerZ);\n   601→                    scene.add(box);\n   602→                    sparseBoxes.push(box);\n   603→                    \n   604→                    // Wireframe outline\n   605→                    const edges = new THREE.EdgesGeometry(boxGeometry);\n   606→                    const lineMaterial = new THREE.LineBasicMaterial({\n   607→                        color: 0x60a5fa,\n   608→                        transparent: true,\n   609→                        opacity: 0.4,\n   610→                        linewidth: 2\n   611→                    });\n   612→                    const wireframe = new THREE.LineSegments(edges, lineMaterial);\n   613→                    wireframe.position.copy(box.position);\n   614→                    scene.add(wireframe);\n   615→                    sparseBoxes.push(wireframe);\n   616→                });\n   617→            }\n   618→        }\n   619→\n   620→        // Camera presets\n   621→        function setView(preset) {\n   622→            controls.autoRotate = false;\n   623→            autoRotate = false;\n   624→            document.getElementById('rotate-btn').classList.remove('active');\n   625→            \n   626→            const duration = 1000;\n   627→            const startPos = camera.position.clone();\n   628→            const startTarget = controls.target.clone();\n   629→            let endPos, endTarget;\n   630→            \n   631→            switch(preset) {\n   632→                case 'overview':\n   633→                    endPos = new THREE.Vector3(80, 60, 80);\n   634→                    endTarget = new THREE.Vector3(0, 0, 0);\n   635→                    break;\n   636→                case 'families':\n   637→                    endPos = new THREE.Vector3(0, 100, 0);\n   638→                    endTarget = new THREE.Vector3(0, 0, 0);\n   639→                    break;\n   640→                case 'sparse':\n   641→                    endPos = new THREE.Vector3(50, 30, 50);\n   642→                    endTarget = new THREE.Vector3(0, -10, 0);\n   643→                    break;\n   644→                case 'highTc':\n   645→                    endPos = new THREE.Vector3(40, 50, 40);\n   646→                    endTarget = new THREE.Vector3(0, 20, 0);\n   647→                    break;\n   648→            }\n   649→            \n   650→            const startTime = Date.now();\n   651→            function animate() {\n   652→                const elapsed = Date.now() - startTime;\n   653→                const t = Math.min(elapsed / duration, 1);\n   654→                const eased = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t; // easeInOutQuad\n   655→                \n   656→                camera.position.lerpVectors(startPos, endPos, eased);\n   657→                controls.target.lerpVectors(startTarget, endTarget, eased);\n   658→                controls.update();\n   659→                \n   660→                if (t < 1) requestAnimationFrame(animate);\n   661→            }\n   662→            animate();\n   663→        }\n   664→\n   665→        function resetCamera() {\n   666→            setView('overview');\n   667→        }\n   668→\n   669→        function toggleRotation() {\n   670→            autoRotate = !autoRotate;\n   671→            controls.autoRotate = autoRotate;\n   672→            document.getElementById('rotate-btn').classList.toggle('active');\n   673→        }\n   674→\n   675→        function toggleCluster(cluster) {\n   676→            clusterVisibility[cluster] = !clusterVisibility[cluster];\n   677→            \n   678→            // Update legend item appearance\n   679→            const items = document.querySelectorAll('.legend-item');\n   680→            items[cluster].classList.toggle('dimmed');\n   681→            \n   682→            // Update point visibility\n   683→            if (pointsMesh) {\n   684→                const colors = pointsMesh.geometry.attributes.color.array;\n   685→                const originalColors = materials.map(m => clusterColors[m.cluster]);\n   686→                \n   687→                materials.forEach((material, i) => {\n   688→                    if (material.cluster === cluster) {\n   689→                        const alpha = clusterVisibility[cluster] ? 1 : 0.05;\n   690→                        const color = originalColors[i];\n   691→                        colors[i * 3] = color.r * alpha;\n   692→                        colors[i * 3 + 1] = color.g * alpha;\n   693→                        colors[i * 3 + 2] = color.b * alpha;\n   694→                    }\n   695→                });\n   696→                \n   697→                pointsMesh.geometry.attributes.color.needsUpdate = true;\n   698→            }\n   699→        }\n   700→\n   701→        // Raycasting for hover tooltips\n   702→        const raycaster = new THREE.Raycaster();\n   703→        raycaster.params.Points.threshold = 1;\n   704→        const mouse = new THREE.Vector2();\n   705→        const tooltip = document.getElementById('tooltip');\n   706→        let lastHoveredIndex = -1;\n   707→\n   708→        renderer.domElement.addEventListener('mousemove', (event) => {\n   709→            const rect = container.getBoundingClientRect();\n   710→            mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;\n   711→            mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;\n   712→        });\n   713→\n   714→        // Animation loop\n   715→        function animate() {\n   716→            requestAnimationFrame(animate);\n   717→            \n   718→            controls.update();\n   719→\n   720→            // Raycasting for tooltips\n   721→            if (pointsMesh) {\n   722→                raycaster.setFromCamera(mouse, camera);\n   723→                const intersects = raycaster.intersectObject(pointsMesh);\n   724→                \n   725→                if (intersects.length > 0) {\n   726→                    const index = intersects[0].index;\n   727→                    \n   728→                    if (index !== lastHoveredIndex && materials[index]) {\n   729→                        const material = materials[index];\n   730→                        const clusterNames = ['Family A', 'Family B', 'Family C'];\n   731→                        \n   732→                        tooltip.innerHTML = `\n   733→                            <div class=\"tooltip-title\">${material.material || 'Superconductor ' + index}</div>\n   734→                            <div class=\"tooltip-row\">\n   735→                                <span class=\"tooltip-label\">Critical Temp:</span>\n   736→                                <span class=\"tooltip-value\">${material.tc.toFixed(1)}K</span>\n   737→                            </div>\n   738→                            <div class=\"tooltip-row\">\n   739→                                <span class=\"tooltip-label\">Cluster:</span>\n   740→                                <span class=\"tooltip-value\">${clusterNames[material.cluster]}</span>\n   741→                            </div>\n   742→                            <div class=\"tooltip-row\">\n   743→                                <span class=\"tooltip-label\">Atomic Mass:</span>\n   744→                                <span class=\"tooltip-value\">${material.atomic_mass.toFixed(1)}</span>\n   745→                            </div>\n   746→                        `;\n   747→                        \n   748→                        const rect = container.getBoundingClientRect();\n   749→                        const x = (mouse.x + 1) * rect.width / 2 + 15;\n   750→                        const y = (-mouse.y + 1) * rect.height / 2 + 15;\n   751→                        \n   752→                        tooltip.style.opacity = '1';\n   753→                        tooltip.style.left = x + 'px';\n   754→                        tooltip.style.top = y + 'px';\n   755→                        lastHoveredIndex = index;\n   756→                    }\n   757→                } else {\n   758→                    tooltip.style.opacity = '0';\n   759→                    lastHoveredIndex = -1;\n   760→                }\n   761→            }\n   762→\n   763→            // Animate sparse boxes (subtle pulse)\n   764→            sparseBoxes.forEach((box, i) => {\n   765→                if (i % 2 === 0) { // Only filled boxes\n   766→                    box.material.opacity = 0.08 + Math.sin(Date.now() * 0.001 + i) * 0.02;\n   767→                }\n   768→            });\n   769→\n   770→            renderer.render(scene, camera);\n   771→        }\n   772→\n   773→        animate();\n   774→\n   775→        // Handle window resize\n   776→        window.addEventListener('resize', () => {\n   777→            camera.aspect = container.clientWidth / container.clientHeight;\n   778→            camera.updateProjectionMatrix();\n   779→            renderer.setSize(container.clientWidth, container.clientHeight);\n   780→        });\n   781→\n   782→        // Keyboard shortcuts\n   783→        document.addEventListener('keydown', (e) => {\n   784→            switch(e.key) {\n   785→                case '1': setView('overview'); break;\n   786→                case '2': setView('families'); break;\n   787→                case '3': setView('sparse'); break;\n   788→                case '4': setView('highTc'); break;\n   789→                case 'r': resetCamera(); break;\n   790→                case ' ': toggleRotation(); break;\n   791→            }\n   792→        });\n   793→    </script>\n   794→</body>\n   795→</html>\n   796→"}]},"parent_tool_use_id":"toolu_01D46jGHkBn8U52ZLELXY6Dh","session_id":"df77d6ed-acd7-4370-ab29-6b857b89c4cf","uuid":"57f19144-e335-4aca-857d-671f61605d2c"}
