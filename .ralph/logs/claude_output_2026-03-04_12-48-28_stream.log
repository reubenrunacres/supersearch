r-color: rgba(255, 255, 255, 0.8);\n   154→        }\n   155→\n   156→        .legend-label {\n   157→            font-family: 'Fragment Mono', monospace;\n   158→            font-size: 0.8125rem;\n   159→            color: #e8e8e8;\n   160→        }\n   161→\n   162→        .legend-count {\n   163→            font-size: 0.75rem;\n   164→            color: #666;\n   165→            margin-left: auto;\n   166→            padding-left: 12px;\n   167→        }\n   168→\n   169→        .tc-gradient {\n   170→            width: 100%;\n   171→            height: 24px;\n   172→            background: linear-gradient(to right, #3b82f6, #8b5cf6, #ec4899);\n   173→            border-radius: 6px;\n   174→            margin: 12px 0 8px 0;\n   175→            border: 1px solid rgba(255, 255, 255, 0.1);\n   176→        }\n   177→\n   178→        .tc-labels {\n   179→            display: flex;\n   180→            justify-content: space-between;\n   181→            font-family: 'Fragment Mono', monospace;\n   182→            font-size: 0.75rem;\n   183→            color: #888;\n   184→            margin-bottom: 16px;\n   185→        }\n   186→\n   187→        .control-group {\n   188→            margin-bottom: 20px;\n   189→        }\n   190→\n   191→        .control-label {\n   192→            font-family: 'Fragment Mono', monospace;\n   193→            font-size: 0.75rem;\n   194→            color: #666;\n   195→            margin-bottom: 8px;\n   196→            text-transform: uppercase;\n   197→            letter-spacing: 0.1em;\n   198→            font-weight: 600;\n   199→        }\n   200→\n   201→        button {\n   202→            background: rgba(59, 130, 246, 0.15);\n   203→            border: 1px solid rgba(59, 130, 246, 0.4);\n   204→            color: #60a5fa;\n   205→            padding: 10px 18px;\n   206→            border-radius: 8px;\n   207→            font-family: 'Fragment Mono', monospace;\n   208→            font-size: 0.8125rem;\n   209→            cursor: pointer;\n   210→            transition: all 0.2s;\n   211→            width: 100%;\n   212→            font-weight: 500;\n   213→        }\n   214→\n   215→        button:hover {\n   216→            background: rgba(59, 130, 246, 0.25);\n   217→            border-color: #3b82f6;\n   218→            transform: translateY(-1px);\n   219→            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);\n   220→        }\n   221→\n   222→        button.active {\n   223→            background: rgba(59, 130, 246, 0.3);\n   224→            border-color: #3b82f6;\n   225→            color: #ffffff;\n   226→        }\n   227→\n   228→        .button-group {\n   229→            display: grid;\n   230→            grid-template-columns: 1fr 1fr;\n   231→            gap: 8px;\n   232→            margin-bottom: 12px;\n   233→        }\n   234→\n   235→        .button-group button {\n   236→            font-size: 0.75rem;\n   237→            padding: 8px 12px;\n   238→        }\n   239→\n   240→        #tooltip {\n   241→            position: absolute;\n   242→            background: rgba(10, 14, 26, 0.95);\n   243→            backdrop-filter: blur(20px);\n   244→            border: 1px solid rgba(255, 255, 255, 0.2);\n   245→            padding: 16px 20px;\n   246→            border-radius: 10px;\n   247→            font-family: 'Fragment Mono', monospace;\n   248→            font-size: 0.8125rem;\n   249→            line-height: 1.8;\n   250→            pointer-events: none;\n   251→            opacity: 0;\n   252→            transition: opacity 0.2s;\n   253→            z-index: 1000;\n   254→            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n   255→        }\n   256→\n   257→        .tooltip-title {\n   258→            font-size: 0.9375rem;\n   259→            color: #ffffff;\n   260→            margin-bottom: 6px;\n   261→            font-weight: 600;\n   262→        }\n   263→\n   264→        .tooltip-row {\n   265→            display: flex;\n   266→            justify-content: space-between;\n   267→            margin-bottom: 2px;\n   268→        }\n   269→\n   270→        .tooltip-label {\n   271→            color: #888;\n   272→        }\n   273→\n   274→        .tooltip-value {\n   275→            color: #60a5fa;\n   276→            font-weight: 600;\n   277→        }\n   278→\n   279→        .stat-value {\n   280→            color: #60a5fa;\n   281→            font-weight: 600;\n   282→        }\n   283→\n   284→        .stat-label {\n   285→            color: #888;\n   286→        }\n   287→\n   288→        .instructions {\n   289→            margin-top: 20px;\n   290→            padding-top: 20px;\n   291→            border-top: 1px solid rgba(255, 255, 255, 0.08);\n   292→            font-size: 0.75rem;\n   293→            color: #666;\n   294→            line-height: 1.8;\n   295→        }\n   296→\n   297→        .instruction-row {\n   298→            margin-bottom: 4px;\n   299→        }\n   300→\n   301→        #loading {\n   302→            position: absolute;\n   303→            top: 50%;\n   304→            left: 50%;\n   305→            transform: translate(-50%, -50%);\n   306→            text-align: center;\n   307→            pointer-events: none;\n   308→        }\n   309→\n   310→        .loading-spinner {\n   311→            width: 50px;\n   312→            height: 50px;\n   313→            border: 3px solid rgba(59, 130, 246, 0.1);\n   314→            border-top-color: #3b82f6;\n   315→            border-radius: 50%;\n   316→            animation: spin 1s linear infinite;\n   317→            margin: 0 auto 20px;\n   318→        }\n   319→\n   320→        @keyframes spin {\n   321→            to { transform: rotate(360deg); }\n   322→        }\n   323→\n   324→        .loading-text {\n   325→            font-family: 'Fragment Mono', monospace;\n   326→            color: #888;\n   327→            font-size: 0.875rem;\n   328→        }\n   329→\n   330→        @media (max-width: 768px) {\n   331→            #header, #controls, #stats, #legend {\n   332→                position: relative;\n   333→                margin: 10px;\n   334→            }\n   335→        }\n   336→    </style>\n   337→</head>\n   338→<body>\n   339→    <div id=\"container\">\n   340→        <div id=\"canvas-container\"></div>\n   341→        \n   342→        <div id=\"ui-overlay\">\n   343→            <div id=\"header\">\n   344→                <h1>SuperSearch</h1>\n   345→                <div class=\"subtitle\">21,263 superconductors mapped in 3D composition space</div>\n   346→            </div>\n   347→\n   348→            <div id=\"controls\">\n   349→                <div class=\"control-group\">\n   350→                    <div class=\"control-label\">Camera Presets</div>\n   351→                    <div class=\"button-group\">\n   352→                        <button onclick=\"setView('overview')\">Overview</button>\n   353→                        <button onclick=\"setView('families')\">Families</button>\n   354→                        <button onclick=\"setView('sparse')\">Sparse</button>\n   355→                        <button onclick=\"setView('highTc')\">High-Tc</button>\n   356→                    </div>\n   357→                </div>\n   358→                \n   359→                <div class=\"control-group\">\n   360→                    <div class=\"control-label\">View Mode</div>\n   361→                    <button id=\"rotate-btn\" class=\"active\" onclick=\"toggleRotation()\">Auto-Rotate</button>\n   362→                </div>\n   363→                \n   364→                <div class=\"control-group\">\n   365→                    <button onclick=\"resetCamera()\">Reset View</button>\n   366→                </div>\n   367→                \n   368→                <div class=\"instructions\">\n   369→                    <div class=\"instruction-row\">🖱️ Drag to rotate</div>\n   370→                    <div class=\"instruction-row\">🔍 Scroll to zoom</div>\n   371→                    <div class=\"instruction-row\">⇧ Right-drag to pan</div>\n   372→                    <div class=\"instruction-row\">💡 Hover for details</div>\n   373→                    <div class=\"instruction-row\">👆 Click legend to filter</div>\n   374→                </div>\n   375→            </div>\n   376→\n   377→            <div id=\"stats\">\n   378→                <div><span class=\"stat-label\">Materials:</span> <span class=\"stat-value\">21,263</span></div>\n   379→                <div><span class=\"stat-label\">Families:</span> <span class=\"stat-value\">3</span></div>\n   380→                <div><span class=\"stat-label\">Sparse Regions:</span> <span class=\"stat-value\">34</span></div>\n   381→                <div><span class=\"stat-label\">Tc Range:</span> <span class=\"stat-value\">0-185K</span></div>\n   382→                <div><span class=\"stat-label\">Variance:</span> <span class=\"stat-value\">73.5%</span></div>\n   383→            </div>\n   384→\n   385→            <div id=\"legend\">\n   386→                <div class=\"section-title\">Composition Families</div>\n   387→                <div class=\"legend-item\" onclick=\"toggleCluster(0)\">\n   388→                    <div class=\"legend-color\" style=\"background: #3b82f6;\"></div>\n   389→                    <div class=\"legend-label\">Family A</div>\n   390→                    <div class=\"legend-count\" id=\"count-0\">0</div>\n   391→                </div>\n   392→                <div class=\"legend-item\" onclick=\"toggleCluster(1)\">\n   393→                    <div class=\"legend-color\" style=\"background: #8b5cf6;\"></div>\n   394→                    <div class=\"legend-label\">Family B</div>\n   395→                    <div class=\"legend-count\" id=\"count-1\">0</div>\n   396→                </div>\n   397→                <div class=\"legend-item\" onclick=\"toggleCluster(2)\">\n   398→                    <div class=\"legend-color\" style=\"background: #ec4899;\"></div>\n   399→                    <div class=\"legend-label\">Family C</div>\n   400→                    <div class=\"legend-count\" id=\"count-2\">0</div>\n   401→                </div>\n   402→                \n   403→                <div class=\"section-title\" style=\"margin-top: 24px;\">Critical Temperature</div>\n   404→                <div class=\"tc-gradient\"></div>\n   405→                <div class=\"tc-labels\">\n   406→                    <span>0K</span>\n   407→                    <span>93K</span>\n   408→                    <span>185K</span>\n   409→                </div>\n   410→            </div>\n   411→        </div>\n   412→\n   413→        <div id=\"loading\">\n   414→            <div class=\"loading-spinner\"></div>\n   415→            <div class=\"loading-text\">Loading 21,263 materials...</div>\n   416→        </div>\n   417→\n   418→        <div id=\"tooltip\"></div>\n   419→    </div>\n   420→\n   421→    <script>\n   422→        // Scene setup\n   423→        const scene = new THREE.Scene();\n   424→        scene.background = new THREE.Color(0x0a0e1a);\n   425→        scene.fog = new THREE.FogExp2(0x0a0e1a, 0.002);\n   426→\n   427→        const container = document.getElementById('canvas-container');\n   428→        const camera = new THREE.PerspectiveCamera(\n   429→            50,\n   430→            container.clientWidth / container.clientHeight,\n   431→            0.1,\n   432→            1000\n   433→        );\n   434→        camera.position.set(80, 60, 80);\n   435→\n   436→        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });\n   437→        renderer.setSize(container.clientWidth, container.clientHeight);\n   438→        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n   439→        container.appendChild(renderer.domElement);\n   440→\n   441→        // Orbit controls\n   442→        const controls = new THREE.OrbitControls(camera, renderer.domElement);\n   443→        controls.enableDamping = true;\n   444→        controls.dampingFactor = 0.05;\n   445→        controls.minDistance = 30;\n   446→        controls.maxDistance = 200;\n   447→        controls.maxPolarAngle = Math.PI * 0.95;\n   448→        controls.autoRotate = true;\n   449→        controls.autoRotateSpeed = 0.3;\n   450→\n   451→        // Lighting\n   452→        const ambientLight = new THREE.AmbientLight(0xffffff, 0.3);\n   453→        scene.add(ambientLight);\n   454→\n   455→        const pointLight1 = new THREE.PointLight(0x3b82f6, 2, 300);\n   456→        pointLight1.position.set(60, 60, 60);\n   457→        scene.add(pointLight1);\n   458→\n   459→        const pointLight2 = new THREE.PointLight(0xec4899, 1.5, 300);\n   460→        pointLight2.position.set(-60, -40, -60);\n   461→        scene.add(pointLight2);\n   462→\n   463→        const pointLight3 = new THREE.PointLight(0x8b5cf6, 1, 200);\n   464→        pointLight3.position.set(0, 80, 0);\n   465→        scene.add(pointLight3);\n   466→\n   467→        // Grid and axes\n   468→        const gridHelper = new THREE.GridHelper(120, 24, 0x2563eb, 0x1a1f2e);\n   469→        gridHelper.position.y = -40;\n   470→        scene.add(gridHelper);\n   471→\n   472→        const axesHelper = new THREE.AxesHelper(50);\n   473→        scene.add(axesHelper);\n   474→\n   475→        // Data structures\n   476→        let pointsMesh;\n   477→        let sparseBoxes = [];\n   478→        let materials = [];\n   479→        let clusterVisibility = [true, true, true];\n   480→        let autoRotate = true;\n   481→\n   482→        // Cluster colors\n   483→        const clusterColors = [\n   484→            new THREE.Color(0x3b82f6), // Blue\n   485→            new THREE.Color(0x8b5cf6), // Purple\n   486→            new THREE.Color(0xec4899)  // Pink\n   487→        ];\n   488→\n   489→        // Load and visualize data\n   490→        fetch('data/analysis_results.json')\n   491→            .then(response => response.json())\n   492→            .then(data => {\n   493→                materials = data.materials;\n   494→                createVisualization(data);\n   495→                document.getElementById('loading').style.display = 'none';\n   496→            })\n   497→            .catch(error => {\n   498→                console.error('Error loading data:', error);\n   499→                document.getElementById('loading').innerHTML = '<div class=\"loading-text\" style=\"color: #ef4444;\">Error loading data</div>';\n   500→            });\n   501→\n   502→        function createVisualization(data) {\n   503→            // Calculate data extents\n   504→            const xExtent = [Math.min(...data.materials.map(m => m.x)), Math.max(...data.materials.map(m => m.x))];\n   505→            const yExtent = [Math.min(...data.materials.map(m => m.y)), Math.max(...data.materials.map(m => m.y))];\n   506→            const tcExtent = [data.metadata.tc_range.min, data.metadata.tc_range.max];\n   507→            \n   508→            // Better scaling - spread across full 3D space\n   509→            const scaleX = 60;\n   510→            const scaleY = 60;\n   511→            const scaleZ = 60;\n   512→            \n   513→            const xScale = (x) => ((x - xExtent[0]) / (xExtent[1] - xExtent[0]) - 0.5) * scaleX;\n   514→            const yScale = (y) => ((y - yExtent[0]) / (yExtent[1] - yExtent[0]) - 0.5) * scaleY;\n   515→            const zScale = (tc) => ((tc - tcExtent[0]) / (tcExtent[1] - tcExtent[0]) - 0.5) * scaleZ;\n   516→\n   517→            // Create sprite texture for points (better than plain dots)\n   518→            const canvas = document.createElement('canvas');\n   519→            canvas.width = 32;\n   520→            canvas.height = 32;\n   521→            const ctx = canvas.getContext('2d');\n   522→            const gradient = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);\n   523→            gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');\n   524→            gradient.addColorStop(0.3, 'rgba(255, 255, 255, 0.8)');\n   525→            gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');\n   526→            ctx.fillStyle = gradient;\n   527→            ctx.fillRect(0, 0, 32, 32);\n   528→            const sprite = new THREE.CanvasTexture(canvas);\n   529→\n   530→            // Create points geometry\n   531→            const geometry = new THREE.BufferGeometry();\n   532→            const positions = [];\n   533→            const colors = [];\n   534→            const sizes = [];\n   535→\n   536→            // Count by cluster\n   537→            const clusterCounts = [0, 0, 0];\n   538→\n   539→            data.materials.forEach(material => {\n   540→                const x = xScale(material.x);\n   541→                const y = zScale(material.tc);\n   542→                const z = yScale(material.y);\n   543→                \n   544→                positions.push(x, y, z);\n   545→                \n   546→                // Use cluster color\n   547→                const color = clusterColors[material.cluster];\n   548→                colors.push(color.r, color.g, color.b);\n   549→                \n   550→                // Vary size by Tc (higher Tc = bigger)\n   551→                const size = 0.5 + (material.tc / tcExtent[1]) * 1.5;\n   552→                sizes.push(size);\n   553→                \n   554→                clusterCounts[material.cluster]++;\n   555→            });\n   556→\n   557→            // Update counts in legend\n   558→            document.getElementById('count-0').textContent = clusterCounts[0].toLocaleString();\n   559→            document.getElementById('count-1').textContent = clusterCounts[1].toLocaleString();\n   560→            document.getElementById('count-2').textContent = clusterCounts[2].toLocaleString();\n   561→\n   562→            geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));\n   563→            geometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));\n   564→            geometry.setAttribute('size', new THREE.Float32BufferAttribute(sizes, 1));\n   565→\n   566→            const material = new THREE.PointsMaterial({\n   567→                size: 1.2,\n   568→                vertexColors: true,\n   569→                transparent: true,\n   570→                opacity: 0.85,\n   571→                sizeAttenuation: true,\n   572→                map: sprite,\n   573→                blending: THREE.AdditiveBlending,\n   574→                depthWrite: false\n   575→            });\n   576→\n   577→            pointsMesh = new THREE.Points(geometry, material);\n   578→            scene.add(pointsMesh);\n   579→\n   580→            // Create sparse region boxes (make them VISIBLE and IMPRESSIVE)\n   581→            if (data.sparse_regions) {\n   582→                const gridSize = 1.5; // Approximate grid cell size\n   583→                \n   584→                data.sparse_regions.forEach((region, index) => {\n   585→                    const centerX = xScale(region.x);\n   586→                    const centerZ = yScale(region.y);\n   587→                    \n   588→                    // Create filled box with glow\n   589→                    const boxGeometry = new THREE.BoxGeometry(gridSize * 2, scaleZ * 0.8, gridSize * 2);\n   590→                    \n   591→                    // Filled box\n   592→                    const boxMaterial = new THREE.MeshBasicMaterial({\n   593→                        color: 0x3b82f6,\n   594→                        transparent: true,\n   595→                        opacity: 0.08,\n   596→                        side: THREE.DoubleSide\n   597→                    });\n   598→                    \n   599→                    const box = new THREE.Mesh(boxGeometry, boxMaterial);\n   600→                    box.position.set(centerX, 0, centerZ);\n   601→                    scene.add(box);\n   602→                    sparseBoxes.push(box);\n   603→                    \n   604→                    // Wireframe outline\n   605→                    const edges = new THREE.EdgesGeometry(boxGeometry);\n   606→                    const lineMaterial = new THREE.LineBasicMaterial({\n   607→                        color: 0x60a5fa,\n   608→                        transparent: true,\n   609→                        opacity: 0.4,\n   610→                        linewidth: 2\n   611→                    });\n   612→                    const wireframe = new THREE.LineSegments(edges, lineMaterial);\n   613→                    wireframe.position.copy(box.position);\n   614→                    scene.add(wireframe);\n   615→                    sparseBoxes.push(wireframe);\n   616→                });\n   617→            }\n   618→        }\n   619→\n   620→        // Camera presets\n   621→        function setView(preset) {\n   622→            controls.autoRotate = false;\n   623→            autoRotate = false;\n   624→            document.getElementById('rotate-btn').classList.remove('active');\n   625→            \n   626→            const duration = 1000;\n   627→            const startPos = camera.position.clone();\n   628→            const startTarget = controls.target.clone();\n   629→            let endPos, endTarget;\n   630→            \n   631→            switch(preset) {\n   632→                case 'overview':\n   633→                    endPos = new THREE.Vector3(80, 60, 80);\n   634→                    endTarget = new THREE.Vector3(0, 0, 0);\n   635→                    break;\n   636→                case 'families':\n   637→                    endPos = new THREE.Vector3(0, 100, 0);\n   638→                    endTarget = new THREE.Vector3(0, 0, 0);\n   639→                    break;\n   640→                case 'sparse':\n   641→                    endPos = new THREE.Vector3(50, 30, 50);\n   642→                    endTarget = new THREE.Vector3(0, -10, 0);\n   643→                    break;\n   644→                case 'highTc':\n   645→                    endPos = new THREE.Vector3(40, 50, 40);\n   646→                    endTarget = new THREE.Vector3(0, 20, 0);\n   647→                    break;\n   648→            }\n   649→            \n   650→            const startTime = Date.now();\n   651→            function animate() {\n   652→                const elapsed = Date.now() - startTime;\n   653→                const t = Math.min(elapsed / duration, 1);\n   654→                const eased = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t; // easeInOutQuad\n   655→                \n   656→                camera.position.lerpVectors(startPos, endPos, eased);\n   657→                controls.target.lerpVectors(startTarget, endTarget, eased);\n   658→                controls.update();\n   659→                \n   660→                if (t < 1) requestAnimationFrame(animate);\n   661→            }\n   662→            animate();\n   663→        }\n   664→\n   665→        function resetCamera() {\n   666→            setView('overview');\n   667→        }\n   668→\n   669→        function toggleRotation() {\n   670→            autoRotate = !autoRotate;\n   671→            controls.autoRotate = autoRotate;\n   672→            document.getElementById('rotate-btn').classList.toggle('active');\n   673→        }\n   674→\n   675→        function toggleCluster(cluster) {\n   676→            clusterVisibility[cluster] = !clusterVisibility[cluster];\n   677→            \n   678→            // Update legend item appearance\n   679→            const items = document.querySelectorAll('.legend-item');\n   680→            items[cluster].classList.toggle('dimmed');\n   681→            \n   682→            // Update point visibility\n   683→            if (pointsMesh) {\n   684→                const colors = pointsMesh.geometry.attributes.color.array;\n   685→                const originalColors = materials.map(m => clusterColors[m.cluster]);\n   686→                \n   687→                materials.forEach((material, i) => {\n   688→                    if (material.cluster === cluster) {\n   689→                        const alpha = clusterVisibility[cluster] ? 1 : 0.05;\n   690→                        const color = originalColors[i];\n   691→                        colors[i * 3] = color.r * alpha;\n   692→                        colors[i * 3 + 1] = color.g * alpha;\n   693→                        colors[i * 3 + 2] = color.b * alpha;\n   694→                    }\n   695→                });\n   696→                \n   697→                pointsMesh.geometry.attributes.color.needsUpdate = true;\n   698→            }\n   699→        }\n   700→\n   701→        // Raycasting for hover tooltips\n   702→        const raycaster = new THREE.Raycaster();\n   703→        raycaster.params.Points.threshold = 1;\n   704→        const mouse = new THREE.Vector2();\n   705→        const tooltip = document.getElementById('tooltip');\n   706→        let lastHoveredIndex = -1;\n   707→\n   708→        renderer.domElement.addEventListener('mousemove', (event) => {\n   709→            const rect = container.getBoundingClientRect();\n   710→            mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;\n   711→            mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;\n   712→        });\n   713→\n   714→        // Animation loop\n   715→        function animate() {\n   716→            requestAnimationFrame(animate);\n   717→            \n   718→            controls.update();\n   719→\n   720→            // Raycasting for tooltips\n   721→            if (pointsMesh) {\n   722→                raycaster.setFromCamera(mouse, camera);\n   723→                const intersects = raycaster.intersectObject(pointsMesh);\n   724→                \n   725→                if (intersects.length > 0) {\n   726→                    const index = intersects[0].index;\n   727→                    \n   728→                    if (index !== lastHoveredIndex && materials[index]) {\n   729→                        const material = materials[index];\n   730→                        const clusterNames = ['Family A', 'Family B', 'Family C'];\n   731→                        \n   732→                        tooltip.innerHTML = `\n   733→                            <div class=\"tooltip-title\">${material.material || 'Superconductor ' + index}</div>\n   734→                            <div class=\"tooltip-row\">\n   735→                                <span class=\"tooltip-label\">Critical Temp:</span>\n   736→                                <span class=\"tooltip-value\">${material.tc.toFixed(1)}K</span>\n   737→                            </div>\n   738→                            <div class=\"tooltip-row\">\n   739→                                <span class=\"tooltip-label\">Cluster:</span>\n   740→                                <span class=\"tooltip-value\">${clusterNames[material.cluster]}</span>\n   741→                            </div>\n   742→                            <div class=\"tooltip-row\">\n   743→                                <span class=\"tooltip-label\">Atomic Mass:</span>\n   744→                                <span class=\"tooltip-value\">${material.atomic_mass.toFixed(1)}</span>\n   745→                            </div>\n   746→                        `;\n   747→                        \n   748→                        const rect = container.getBoundingClientRect();\n   749→                        const x = (mouse.x + 1) * rect.width / 2 + 15;\n   750→                        const y = (-mouse.y + 1) * rect.height / 2 + 15;\n   751→                        \n   752→                        tooltip.style.opacity = '1';\n   753→                        tooltip.style.left = x + 'px';\n   754→                        tooltip.style.top = y + 'px';\n   755→                        lastHoveredIndex = index;\n   756→                    }\n   757→                } else {\n   758→                    tooltip.style.opacity = '0';\n   759→                    lastHoveredIndex = -1;\n   760→                }\n   761→            }\n   762→\n   763→            // Animate sparse boxes (subtle pulse)\n   764→            sparseBoxes.forEach((box, i) => {\n   765→                if (i % 2 === 0) { // Only filled boxes\n   766→                    box.material.opacity = 0.08 + Math.sin(Date.now() * 0.001 + i) * 0.02;\n   767→                }\n   768→            });\n   769→\n   770→            renderer.render(scene, camera);\n   771→        }\n   772→\n   773→        animate();\n   774→\n   775→        // Handle window resize\n   776→        window.addEventListener('resize', () => {\n   777→            camera.aspect = container.clientWidth / container.clientHeight;\n   778→            camera.updateProjectionMatrix();\n   779→            renderer.setSize(container.clientWidth, container.clientHeight);\n   780→        });\n   781→\n   782→        // Keyboard shortcuts\n   783→        document.addEventListener('keydown', (e) => {\n   784→            switch(e.key) {\n   785→                case '1': setView('overview'); break;\n   786→                case '2': setView('families'); break;\n   787→                case '3': setView('sparse'); break;\n   788→                case '4': setView('highTc'); break;\n   789→                case 'r': resetCamera(); break;\n   790→                case ' ': toggleRotation(); break;\n   791→            }\n   792→        });\n   793→    </script>\n   794→</body>\n   795→</html>\n   796→"}]},"parent_tool_use_id":null,"session_id":"df77d6ed-acd7-4370-ab29-6b857b89c4cf","uuid":"93135781-bebc-4f84-91a9-7a19a8c4b219","tool_use_result":{"type":"text","file":{"filePath":"/Users/03-mac-alpha/.openclaw/workspace/supersearch/docs/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SuperSearch - Superconductor Composition Explorer</title>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/EffectComposer.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/RenderPass.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/UnrealBloomPass.js\"></script>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Fragment+Mono:wght@400&family=Inter:wght@400;600&display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Inter', -apple-system, sans-serif;\n            background: #0a0e1a;\n            color: #e8e8e8;\n            line-height: 1.65;\n            font-size: 16px;\n            overflow: hidden;\n        }\n\n        #container {\n            position: relative;\n            width: 100vw;\n            height: 100vh;\n        }\n\n        #canvas-container {\n            width: 100%;\n            height: 100%;\n        }\n\n        #ui-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            pointer-events: none;\n        }\n\n        #header {\n            position: absolute;\n            top: 40px;\n            left: 40px;\n            pointer-events: auto;\n        }\n\n        h1 {\n            font-family: 'Fragment Mono', monospace;\n            font-size: 1.5rem;\n            font-weight: 400;\n            color: #ffffff;\n            margin-bottom: 8px;\n            letter-spacing: -0.02em;\n        }\n\n        .subtitle {\n            font-size: 0.875rem;\n            color: #888;\n            font-family: 'Fragment Mono', monospace;\n        }\n\n        #controls {\n            position: absolute;\n            top: 40px;\n            right: 40px;\n            background: rgba(20, 24, 35, 0.85);\n            backdrop-filter: blur(20px);\n            padding: 24px;\n            border-radius: 12px;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            pointer-events: auto;\n            min-width: 240px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n        }\n\n        #stats {\n            position: absolute;\n            bottom: 40px;\n            left: 40px;\n            background: rgba(20, 24, 35, 0.85);\n            backdrop-filter: blur(20px);\n            padding: 24px;\n            border-radius: 12px;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            pointer-events: auto;\n            font-family: 'Fragment Mono', monospace;\n            font-size: 0.8125rem;\n            line-height: 2;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n        }\n\n        #legend {\n            position: absolute;\n            bottom: 40px;\n            right: 40px;\n            background: rgba(20, 24, 35, 0.85);\n            backdrop-filter: blur(20px);\n            padding: 24px;\n            border-radius: 12px;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            pointer-events: auto;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n        }\n\n        .section-title {\n            font-family: 'Fragment Mono', monospace;\n            font-size: 0.75rem;\n            color: #666;\n            margin-bottom: 12px;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n            font-weight: 600;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            margin-bottom: 10px;\n            cursor: pointer;\n            transition: all 0.2s;\n        }\n\n        .legend-item:hover {\n            transform: translateX(4px);\n        }\n\n        .legend-item.dimmed {\n            opacity: 0.3;\n        }\n\n        .legend-color {\n            width: 16px;\n            height: 16px;\n            border-radius: 50%;\n            margin-right: 10px;\n            border: 2px solid rgba(255, 255, 255, 0.3);\n            transition: all 0.2s;\n        }\n\n        .legend-item:hover .legend-color {\n            transform: scale(1.2);\n            border-color: rgba(255, 255, 255, 0.8);\n        }\n\n        .legend-label {\n            font-family: 'Fragment Mono', monospace;\n            font-size: 0.8125rem;\n            color: #e8e8e8;\n        }\n\n        .legend-count {\n            font-size: 0.75rem;\n            color: #666;\n            margin-left: auto;\n            padding-left: 12px;\n        }\n\n        .tc-gradient {\n            width: 100%;\n            height: 24px;\n            background: linear-gradient(to right, #3b82f6, #8b5cf6, #ec4899);\n            border-radius: 6px;\n            margin: 12px 0 8px 0;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .tc-labels {\n            display: flex;\n            justify-content: space-between;\n            font-family: 'Fragment Mono', monospace;\n            font-size: 0.75rem;\n            color: #888;\n            margin-bottom: 16px;\n        }\n\n        .control-group {\n            margin-bottom: 20px;\n        }\n\n        .control-label {\n            font-family: 'Fragment Mono', monospace;\n            font-size: 0.75rem;\n            color: #666;\n            margin-bottom: 8px;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n            font-weight: 600;\n        }\n\n        button {\n            background: rgba(59, 130, 246, 0.15);\n            border: 1px solid rgba(59, 130, 246, 0.4);\n            color: #60a5fa;\n            padding: 10px 18px;\n            border-radius: 8px;\n            font-family: 'Fragment Mono', monospace;\n            font-size: 0.8125rem;\n            cursor: pointer;\n            transition: all 0.2s;\n            width: 100%;\n            font-weight: 500;\n        }\n\n        button:hover {\n            background: rgba(59, 130, 246, 0.25);\n            border-color: #3b82f6;\n            transform: translateY(-1px);\n            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);\n        }\n\n        button.active {\n            background: rgba(59, 130, 246, 0.3);\n            border-color: #3b82f6;\n            color: #ffffff;\n        }\n\n        .button-group {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 8px;\n            margin-bottom: 12px;\n        }\n\n        .button-group button {\n            font-size: 0.75rem;\n            padding: 8px 12px;\n        }\n\n        #tooltip {\n            position: absolute;\n            background: rgba(10, 14, 26, 0.95);\n            backdrop-filter: blur(20px);\n            border: 1px solid rgba(255, 255, 255, 0.2);\n            padding: 16px 20px;\n            border-radius: 10px;\n            font-family: 'Fragment Mono', monospace;\n            font-size: 0.8125rem;\n            line-height: 1.8;\n            pointer-events: none;\n            opacity: 0;\n            transition: opacity 0.2s;\n            z-index: 1000;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n        }\n\n        .tooltip-title {\n            font-size: 0.9375rem;\n            color: #ffffff;\n            margin-bottom: 6px;\n            font-weight: 600;\n        }\n\n        .tooltip-row {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 2px;\n        }\n\n        .tooltip-label {\n            color: #888;\n        }\n\n        .tooltip-value {\n            color: #60a5fa;\n            font-weight: 600;\n        }\n\n        .stat-value {\n            color: #60a5fa;\n            font-weight: 600;\n        }\n\n        .stat-label {\n            color: #888;\n        }\n\n        .instructions {\n            margin-top: 20px;\n            padding-top: 20px;\n            border-top: 1px solid rgba(255, 255, 255, 0.08);\n            font-size: 0.75rem;\n            color: #666;\n            line-height: 1.8;\n        }\n\n        .instruction-row {\n            margin-bottom: 4px;\n        }\n\n        #loading {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            text-align: center;\n            pointer-events: none;\n        }\n\n        .loading-spinner {\n            width: 50px;\n            height: 50px;\n            border: 3px solid rgba(59, 130, 246, 0.1);\n            border-top-color: #3b82f6;\n            border-radius: 50%;\n            animation: spin 1s linear infinite;\n            margin: 0 auto 20px;\n        }\n\n        @keyframes spin {\n            to { transform: rotate(360deg); }\n        }\n\n        .loading-text {\n            font-family: 'Fragment Mono', monospace;\n            color: #888;\n            font-size: 0.875rem;\n        }\n\n        @media (max-width: 768px) {\n            #header, #controls, #stats, #legend {\n                position: relative;\n                margin: 10px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\">\n        <div id=\"canvas-container\"></div>\n        \n        <div id=\"ui-overlay\">\n            <div id=\"header\">\n                <h1>SuperSearch</h1>\n                <div class=\"subtitle\">21,263 superconductors mapped in 3D composition space</div>\n            </div>\n\n            <div id=\"controls\">\n                <div class=\"control-group\">\n                    <div class=\"control-label\">Camera Presets</div>\n                    <div class=\"button-group\">\n                        <button onclick=\"setView('overview')\">Overview</button>\n                        <button onclick=\"setView('families')\">Families</button>\n                        <button onclick=\"setView('sparse')\">Sparse</button>\n                        <button onclick=\"setView('highTc')\">High-Tc</button>\n                    </div>\n                </div>\n                \n                <div class=\"control-group\">\n                    <div class=\"control-label\">View Mode</div>\n                    <button id=\"rotate-btn\" class=\"active\" onclick=\"toggleRotation()\">Auto-Rotate</button>\n                </div>\n                \n                <div class=\"control-group\">\n                    <button onclick=\"resetCamera()\">Reset View</button>\n                </div>\n                \n                <div class=\"instructions\">\n                    <div class=\"instruction-row\">🖱️ Drag to rotate</div>\n                    <div class=\"instruction-row\">🔍 Scroll to zoom</div>\n                    <div class=\"instruction-row\">⇧ Right-drag to pan</div>\n                    <div class=\"instruction-row\">💡 Hover for details</div>\n                    <div class=\"instruction-row\">👆 Click legend to filter</div>\n                </div>\n            </div>\n\n            <div id=\"stats\">\n                <div><span class=\"stat-label\">Materials:</span> <span class=\"stat-value\">21,263</span></div>\n                <div><span class=\"stat-label\">Families:</span> <span class=\"stat-value\">3</span></div>\n                <div><span class=\"stat-label\">Sparse Regions:</span> <span class=\"stat-value\">34</span></div>\n                <div><span class=\"stat-label\">Tc Range:</span> <span class=\"stat-value\">0-185K</span></div>\n                <div><span class=\"stat-label\">Variance:</span> <span class=\"stat-value\">73.5%</span></div>\n            </div>\n\n            <div id=\"legend\">\n                <div class=\"section-title\">Composition Families</div>\n                <div class=\"legend-item\" onclick=\"toggleCluster(0)\">\n                    <div class=\"legend-color\" style=\"background: #3b82f6;\"></div>\n                    <div class=\"legend-label\">Family A</div>\n                    <div class=\"legend-count\" id=\"count-0\">0</div>\n                </div>\n                <div class=\"legend-item\" onclick=\"toggleCluster(1)\">\n                    <div class=\"legend-color\" style=\"background: #8b5cf6;\"></div>\n                    <div class=\"legend-label\">Family B</div>\n                    <div class=\"legend-count\" id=\"count-1\">0</div>\n                </div>\n                <div class=\"legend-item\" onclick=\"toggleCluster(2)\">\n                    <div class=\"legend-color\" style=\"background: #ec4899;\"></div>\n                    <div class=\"legend-label\">Family C</div>\n                    <div class=\"legend-count\" id=\"count-2\">0</div>\n                </div>\n                \n                <div class=\"section-title\" style=\"margin-top: 24px;\">Critical Temperature</div>\n                <div class=\"tc-gradient\"></div>\n                <div class=\"tc-labels\">\n                    <span>0K</span>\n                    <span>93K</span>\n                    <span>185K</span>\n                </div>\n            </div>\n        </div>\n\n        <div id=\"loading\">\n            <div class=\"loading-spinner\"></div>\n            <div class=\"loading-text\">Loading 21,263 materials...</div>\n        </div>\n\n        <div id=\"tooltip\"></div>\n    </div>\n\n    <script>\n        // Scene setup\n        const scene = new THREE.Scene();\n        scene.background = new THREE.Color(0x0a0e1a);\n        scene.fog = new THREE.FogExp2(0x0a0e1a, 0.002);\n\n        const container = document.getElementById('canvas-container');\n        const camera = new THREE.PerspectiveCamera(\n            50,\n            container.clientWidth / container.clientHeight,\n            0.1,\n            1000\n        );\n        camera.position.set(80, 60, 80);\n\n        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });\n        renderer.setSize(container.clientWidth, container.clientHeight);\n        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n        container.appendChild(renderer.domElement);\n\n        // Orbit controls\n        const controls = new THREE.OrbitControls(camera, renderer.domElement);\n        controls.enableDamping = true;\n        controls.dampingFactor = 0.05;\n        controls.minDistance = 30;\n        controls.maxDistance = 200;\n        controls.maxPolarAngle = Math.PI * 0.95;\n        controls.autoRotate = true;\n        controls.autoRotateSpeed = 0.3;\n\n        // Lighting\n        const ambientLight = new THREE.AmbientLight(0xffffff, 0.3);\n        scene.add(ambientLight);\n\n        const pointLight1 = new THREE.PointLight(0x3b82f6, 2, 300);\n        pointLight1.position.set(60, 60, 60);\n        scene.add(pointLight1);\n\n        const pointLight2 = new THREE.PointLight(0xec4899, 1.5, 300);\n        pointLight2.position.set(-60, -40, -60);\n        scene.add(pointLight2);\n\n        const pointLight3 = new THREE.PointLight(0x8b5cf6, 1, 200);\n        pointLight3.position.set(0, 80, 0);\n        scene.add(pointLight3);\n\n        // Grid and axes\n        const gridHelper = new THREE.GridHelper(120, 24, 0x2563eb, 0x1a1f2e);\n        gridHelper.position.y = -40;\n        scene.add(gridHelper);\n\n        const axesHelper = new THREE.AxesHelper(50);\n        scene.add(axesHelper);\n\n        // Data structures\n        let pointsMesh;\n        let sparseBoxes = [];\n        let materials = [];\n        let clusterVisibility = [true, true, true];\n        let autoRotate = true;\n\n        // Cluster colors\n        const clusterColors = [\n            new THREE.Color(0x3b82f6), // Blue\n            new THREE.Color(0x8b5cf6), // Purple\n            new THREE.Color(0xec4899)  // Pink\n        ];\n\n        // Load and visualize data\n        fetch('data/analysis_results.json')\n            .then(response => response.json())\n            .then(data => {\n                materials = data.materials;\n                createVisualization(data);\n                document.getElementById('loading').style.display = 'none';\n            })\n            .catch(error => {\n                console.error('Error loading data:', error);\n                document.getElementById('loading').innerHTML = '<div class=\"loading-text\" style=\"color: #ef4444;\">Error loading data</div>';\n            });\n\n        function createVisualization(data) {\n            // Calculate data extents\n            const xExtent = [Math.min(...data.materials.map(m => m.x)), Math.max(...data.materials.map(m => m.x))];\n            const yExtent = [Math.min(...data.materials.map(m => m.y)), Math.max(...data.materials.map(m => m.y))];\n            const tcExtent = [data.metadata.tc_range.min, data.metadata.tc_range.max];\n            \n            // Better scaling - spread across full 3D space\n            const scaleX = 60;\n            const scaleY = 60;\n            const scaleZ = 60;\n            \n            const xScale = (x) => ((x - xExtent[0]) / (xExtent[1] - xExtent[0]) - 0.5) * scaleX;\n            const yScale = (y) => ((y - yExtent[0]) / (yExtent[1] - yExtent[0]) - 0.5) * scaleY;\n            const zScale = (tc) => ((tc - tcExtent[0]) / (tcExtent[1] - tcExtent[0]) - 0.5) * scaleZ;\n\n            // Create sprite texture for points (better than plain dots)\n            const canvas = document.createElement('canvas');\n            canvas.width = 32;\n            canvas.height = 32;\n            const ctx = canvas.getContext('2d');\n            const gradient = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);\n            gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');\n            gradient.addColorStop(0.3, 'rgba(255, 255, 255, 0.8)');\n            gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');\n            ctx.fillStyle = gradient;\n            ctx.fillRect(0, 0, 32, 32);\n            const sprite = new THREE.CanvasTexture(canvas);\n\n            // Create points geometry\n            const geometry = new THREE.BufferGeometry();\n            const positions = [];\n            const colors = [];\n            const sizes = [];\n\n            // Count by cluster\n            const clusterCounts = [0, 0, 0];\n\n            data.materials.forEach(material => {\n                const x = xScale(material.x);\n                const y = zScale(material.tc);\n                const z = yScale(material.y);\n                \n                positions.push(x, y, z);\n                \n                // Use cluster color\n                const color = clusterColors[material.cluster];\n                colors.push(color.r, color.g, color.b);\n                \n                // Vary size by Tc (higher Tc = bigger)\n                const size = 0.5 + (material.tc / tcExtent[1]) * 1.5;\n                sizes.push(size);\n                \n                clusterCounts[material.cluster]++;\n            });\n\n            // Update counts in legend\n            document.getElementById('count-0').textContent = clusterCounts[0].toLocaleString();\n            document.getElementById('count-1').textContent = clusterCounts[1].toLocaleString();\n            document.getElementById('count-2').textContent = clusterCounts[2].toLocaleString();\n\n            geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));\n            geometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));\n            geometry.setAttribute('size', new THREE.Float32BufferAttribute(sizes, 1));\n\n            const material = new THREE.PointsMaterial({\n                size: 1.2,\n                vertexColors: true,\n                transparent: true,\n                opacity: 0.85,\n                sizeAttenuation: true,\n                map: sprite,\n                blending: THREE.AdditiveBlending,\n                depthWrite: false\n            });\n\n            pointsMesh = new THREE.Points(geometry, material);\n            scene.add(pointsMesh);\n\n            // Create sparse region boxes (make them VISIBLE and IMPRESSIVE)\n            if (data.sparse_regions) {\n                const gridSize = 1.5; // Approximate grid cell size\n                \n                data.sparse_regions.forEach((region, index) => {\n                    const centerX = xScale(region.x);\n                    const centerZ = yScale(region.y);\n                    \n                    // Create filled box with glow\n                    const boxGeometry = new THREE.BoxGeometry(gridSize * 2, scaleZ * 0.8, gridSize * 2);\n                    \n                    // Filled box\n                    const boxMaterial = new THREE.MeshBasicMaterial({\n                        color: 0x3b82f6,\n                        transparent: true,\n                        opacity: 0.08,\n                        side: THREE.DoubleSide\n                    });\n                    \n                    const box = new THREE.Mesh(boxGeometry, boxMaterial);\n                    box.position.set(centerX, 0, centerZ);\n                    scene.add(box);\n                    sparseBoxes.push(box);\n                    \n                    // Wireframe outline\n                    const edges = new THREE.EdgesGeometry(boxGeometry);\n                    const lineMaterial = new THREE.LineBasicMaterial({\n                        color: 0x60a5fa,\n                        transparent: true,\n                        opacity: 0.4,\n                        linewidth: 2\n                    });\n                    const wireframe = new THREE.LineSegments(edges, lineMaterial);\n                    wireframe.position.copy(box.position);\n                    scene.add(wireframe);\n                    sparseBoxes.push(wireframe);\n                });\n            }\n        }\n\n        // Camera presets\n        function setView(preset) {\n            controls.autoRotate = false;\n            autoRotate = false;\n            document.getElementById('rotate-btn').classList.remove('active');\n            \n            const duration = 1000;\n            const startPos = camera.position.clone();\n            const startTarget = controls.target.clone();\n            let endPos, endTarget;\n            \n            switch(preset) {\n                case 'overview':\n                    endPos = new THREE.Vector3(80, 60, 80);\n                    endTarget = new THREE.Vector3(0, 0, 0);\n                    break;\n                case 'families':\n                    endPos = new THREE.Vector3(0, 100, 0);\n                    endTarget = new THREE.Vector3(0, 0, 0);\n                    break;\n                case 'sparse':\n                    endPos = new THREE.Vector3(50, 30, 50);\n                    endTarget = new THREE.Vector3(0, -10, 0);\n                    break;\n                case 'highTc':\n                    endPos = new THREE.Vector3(40, 50, 40);\n                    endTarget = new THREE.Vector3(0, 20, 0);\n                    break;\n            }\n            \n            const startTime = Date.now();\n            function animate() {\n                const elapsed = Date.now() - startTime;\n                const t = Math.min(elapsed / duration, 1);\n                const eased = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t; // easeInOutQuad\n                \n                camera.position.lerpVectors(startPos, endPos, eased);\n                controls.target.lerpVectors(startTarget, endTarget, eased);\n                controls.update();\n                \n                if (t < 1) requestAnimationFrame(animate);\n            }\n            animate();\n        }\n\n        function resetCamera() {\n            setView('overview');\n        }\n\n        function toggleRotation() {\n            autoRotate = !autoRotate;\n            controls.autoRotate = autoRotate;\n            document.getElementById('rotate-btn').classList.toggle('active');\n        }\n\n        function toggleCluster(cluster) {\n            clusterVisibility[cluster] = !clusterVisibility[cluster];\n            \n            // Update legend item appearance\n            const items = document.querySelectorAll('.legend-item');\n            items[cluster].classList.toggle('dimmed');\n            \n            // Update point visibility\n            if (pointsMesh) {\n                const colors = pointsMesh.geometry.attributes.color.array;\n                const originalColors = materials.map(m => clusterColors[m.cluster]);\n                \n                materials.forEach((material, i) => {\n                    if (material.cluster === cluster) {\n                        const alpha = clusterVisibility[cluster] ? 1 : 0.05;\n                        const color = originalColors[i];\n                        colors[i * 3] = color.r * alpha;\n                        colors[i * 3 + 1] = color.g * alpha;\n                        colors[i * 3 + 2] = color.b * alpha;\n                    }\n                });\n                \n                pointsMesh.geometry.attributes.color.needsUpdate = true;\n            }\n        }\n\n        // Raycasting for hover tooltips\n        const raycaster = new THREE.Raycaster();\n        raycaster.params.Points.threshold = 1;\n        const mouse = new THREE.Vector2();\n        const tooltip = document.getElementById('tooltip');\n        let lastHoveredIndex = -1;\n\n        renderer.domElement.addEventListener('mousemove', (event) => {\n            const rect = container.getBoundingClientRect();\n            mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;\n            mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;\n        });\n\n        // Animation loop\n        function animate() {\n            requestAnimationFrame(animate);\n            \n            controls.update();\n\n            // Raycasting for tooltips\n            if (pointsMesh) {\n                raycaster.setFromCamera(mouse, camera);\n                const intersects = raycaster.intersectObject(pointsMesh);\n                \n                if (intersects.length > 0) {\n                    const index = intersects[0].index;\n                    \n                    if (index !== lastHoveredIndex && materials[index]) {\n                        const material = materials[index];\n                        const clusterNames = ['Family A', 'Family B', 'Family C'];\n                        \n                        tooltip.innerHTML = `\n                            <div class=\"tooltip-title\">${material.material || 'Superconductor ' + index}</div>\n                            <div class=\"tooltip-row\">\n                                <span class=\"tooltip-label\">Critical Temp:</span>\n                                <span class=\"tooltip-value\">${material.tc.toFixed(1)}K</span>\n                            </div>\n                            <div class=\"tooltip-row\">\n                                <span class=\"tooltip-label\">Cluster:</span>\n                                <span class=\"tooltip-value\">${clusterNames[material.cluster]}</span>\n                            </div>\n                            <div class=\"tooltip-row\">\n                                <span class=\"tooltip-label\">Atomic Mass:</span>\n                                <span class=\"tooltip-value\">${material.atomic_mass.toFixed(1)}</span>\n                            </div>\n                        `;\n                        \n                        const rect = container.getBoundingClientRect();\n                        const x = (mouse.x + 1) * rect.width / 2 + 15;\n                        const y = (-mouse.y + 1) * rect.height / 2 + 15;\n                        \n                        tooltip.style.opacity = '1';\n                        tooltip.style.left = x + 'px';\n                        tooltip.style.top = y + 'px';\n                        lastHoveredIndex = index;\n                    }\n                } else {\n                    tooltip.style.opacity = '0';\n                    lastHoveredIndex = -1;\n                }\n            }\n\n            // Animate sparse boxes (subtle pulse)\n            sparseBoxes.forEach((box, i) => {\n                if (i % 2 === 0) { // Only filled boxes\n                    box.material.opacity = 0.08 + Math.sin(Date.now() * 0.001 + i) * 0.02;\n                }\n            });\n\n            renderer.render(scene, camera);\n        }\n\n        animate();\n\n        // Handle window resize\n        window.addEventListener('resize', () => {\n            camera.aspect = container.clientWidth / container.clientHeight;\n            camera.updateProjectionMatrix();\n            renderer.setSize(container.clientWidth, container.clientHeight);\n        });\n\n        // Keyboard shortcuts\n        document.addEventListener('keydown', (e) => {\n            switch(e.key) {\n                case '1': setView('overview'); break;\n                case '2': setView('families'); break;\n                case '3': setView('sparse'); break;\n                case '4': setView('highTc'); break;\n                case 'r': resetCamera(); break;\n                case ' ': toggleRotation(); break;\n            }\n        });\n    </script>\n</body>\n</html>\n","numLines":796,"startLine":1,"totalLines":796}}}
