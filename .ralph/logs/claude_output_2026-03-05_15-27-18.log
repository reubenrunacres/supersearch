48→            padding: 15px 20px;\n    49→            font-size: 13px;\n    50→            z-index: 100;\n    51→            backdrop-filter: blur(10px);\n    52→        }\n    53→        \n    54→        #stats {\n    55→            margin-top: 8px;\n    56→            color: #aaa;\n    57→            font-size: 12px;\n    58→        }\n    59→        \n    60→        #canvas {\n    61→            width: 100vw;\n    62→            height: 100vh;\n    63→        }\n    64→        \n    65→        .loading {\n    66→            position: absolute;\n    67→            top: 50%;\n    68→            left: 50%;\n    69→            transform: translate(-50%, -50%);\n    70→            font-size: 16px;\n    71→            color: #3b82f6;\n    72→        }\n    73→    </style>\n    74→</head>\n    75→<body>\n    76→    <div id=\"header\">\n    77→        <div id=\"title\">SuperSearch</div>\n    78→        <div id=\"subtitle\">Superconductor Composition Explorer</div>\n    79→    </div>\n    80→    \n    81→    <div id=\"info\">\n    82→        <div class=\"loading\">Loading materials...</div>\n    83→        <div id=\"stats\"></div>\n    84→    </div>\n    85→    \n    86→    <div id=\"canvas\"></div>\n    87→    \n    88→    <script>\n    89→        const infoDiv = document.querySelector('#info .loading');\n    90→        const statsDiv = document.getElementById('stats');\n    91→        const container = document.getElementById('canvas');\n    92→        \n    93→        // Scene setup\n    94→        const scene = new THREE.Scene();\n    95→        scene.background = new THREE.Color(0x0a0e1a);\n    96→        scene.fog = new THREE.Fog(0x0a0e1a, 50, 200);\n    97→        \n    98→        const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 1000);\n    99→        camera.position.set(80, 60, 80);\n   100→        \n   101→        const renderer = new THREE.WebGLRenderer({ antialias: true });\n   102→        renderer.setSize(window.innerWidth, window.innerHeight);\n   103→        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n   104→        container.appendChild(renderer.domElement);\n   105→        \n   106→        // Controls\n   107→        const controls = new THREE.OrbitControls(camera, renderer.domElement);\n   108→        controls.enableDamping = true;\n   109→        controls.dampingFactor = 0.05;\n   110→        controls.autoRotate = true;\n   111→        controls.autoRotateSpeed = 0.3;\n   112→        \n   113→        // Lighting\n   114→        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);\n   115→        scene.add(ambientLight);\n   116→        \n   117→        const pointLight1 = new THREE.PointLight(0x3b82f6, 2, 300);\n   118→        pointLight1.position.set(60, 60, 60);\n   119→        scene.add(pointLight1);\n   120→        \n   121→        const pointLight2 = new THREE.PointLight(0x8b5cf6, 1.5, 300);\n   122→        pointLight2.position.set(-60, -30, -60);\n   123→        scene.add(pointLight2);\n   124→        \n   125→        // Load and render materials\n   126→        fetch('data/analysis_results_fast.json')\n   127→            .then(r => {\n   128→                if (!r.ok) throw new Error(`HTTP ${r.status}`);\n   129→                return r.json();\n   130→            })\n   131→            .then(data => {\n   132→                const materials = data.materials;\n   133→                infoDiv.textContent = `${materials.length.toLocaleString()} superconductor materials`;\n   134→                \n   135→                // Show stats\n   136→                const clusters = new Set(materials.map(m => m.cluster)).size;\n   137→                const avgTc = (materials.reduce((sum, m) => sum + m.tc, 0) / materials.length).toFixed(1);\n   138→                statsDiv.innerHTML = `${clusters} clusters • Avg Tc: ${avgTc}K`;\n   139→                \n   140→                // Create geometry\n   141→                const geometry = new THREE.BufferGeometry();\n   142→                const positions = [];\n   143→                const colors = [];\n   144→                \n   145→                // Calculate ranges\n   146→                const xVals = materials.map(m => m.x);\n   147→                const yVals = materials.map(m => m.y);\n   148→                const tcVals = materials.map(m => m.tc);\n   149→                \n   150→                const xMin = Math.min(...xVals), xMax = Math.max(...xVals);\n   151→                const yMin = Math.min(...yVals), yMax = Math.max(...yVals);\n   152→                const tcMin = Math.min(...tcVals), tcMax = Math.max(...tcVals);\n   153→                \n   154→                materials.forEach(m => {\n   155→                    // Scale to 3D space\n   156→                    const x = ((m.x - xMin) / (xMax - xMin) - 0.5) * 60;\n   157→                    const y = ((m.tc - tcMin) / (tcMax - tcMin) - 0.5) * 60;\n   158→                    const z = ((m.y - yMin) / (yMax - yMin) - 0.5) * 60;\n   159→                    \n   160→                    positions.push(x, y, z);\n   161→                    \n   162→                    // Color by Tc (blue to pink gradient)\n   163→                    const t = (m.tc - tcMin) / (tcMax - tcMin);\n   164→                    const r = 0.2 + t * 0.8;\n   165→                    const g = 0.3;\n   166→                    const b = 0.9 - t * 0.5;\n   167→                    colors.push(r, g, b);\n   168→                });\n   169→                \n   170→                geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));\n   171→                geometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));\n   172→                \n   173→                const material = new THREE.PointsMaterial({\n   174→                    size: 0.8,\n   175→                    vertexColors: true,\n   176→                    transparent: true,\n   177→                    opacity: 0.8,\n   178→                    sizeAttenuation: true\n   179→                });\n   180→                \n   181→                const points = new THREE.Points(geometry, material);\n   182→                scene.add(points);\n   183→                \n   184→                console.log('✓ Rendered', materials.length, 'materials');\n   185→            })\n   186→            .catch(e => {\n   187→                infoDiv.textContent = 'Error: ' + e.message;\n   188→                infoDiv.style.color = '#ef4444';\n   189→                console.error('Load error:', e);\n   190→            });\n   191→        \n   192→        // Animation loop\n   193→        function animate() {\n   194→            requestAnimationFrame(animate);\n   195→            controls.update();\n   196→            renderer.render(scene, camera);\n   197→        }\n   198→        animate();\n   199→        \n   200→        // Handle window resize\n   201→        window.addEventListener('resize', () => {\n   202→            camera.aspect = window.innerWidth / window.innerHeight;\n   203→            camera.updateProjectionMatrix();\n   204→            renderer.setSize(window.innerWidth, window.innerHeight);\n   205→        });\n   206→    </script>\n   207→</body>\n   208→</html>\n   209→"}]},"parent_tool_use_id":null,"session_id":"971ff8f1-fa70-4e84-a1c2-a5a61f6d92d0","uuid":"84a50aa8-a1c9-4a65-80ee-8e9544a89c38","tool_use_result":{"type":"text","file":{"filePath":"/Users/03-mac-alpha/.openclaw/workspace/supersearch/docs/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SuperSearch - Superconductor Composition Explorer</title>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js\"></script>\n    <style>\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            background: #0a0e1a;\n            color: #e8e8e8;\n            overflow: hidden;\n        }\n        \n        #header {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            padding: 20px 30px;\n            background: linear-gradient(180deg, #0a0e1a 0%, transparent 100%);\n            z-index: 100;\n        }\n        \n        #title {\n            font-size: 24px;\n            font-weight: 700;\n            letter-spacing: -0.5px;\n            margin-bottom: 5px;\n        }\n        \n        #subtitle {\n            font-size: 13px;\n            color: #888;\n            letter-spacing: 0.3px;\n        }\n        \n        #info {\n            position: absolute;\n            bottom: 20px;\n            left: 20px;\n            background: rgba(20, 25, 35, 0.9);\n            border: 1px solid rgba(100, 150, 200, 0.3);\n            border-radius: 8px;\n            padding: 15px 20px;\n            font-size: 13px;\n            z-index: 100;\n            backdrop-filter: blur(10px);\n        }\n        \n        #stats {\n            margin-top: 8px;\n            color: #aaa;\n            font-size: 12px;\n        }\n        \n        #canvas {\n            width: 100vw;\n            height: 100vh;\n        }\n        \n        .loading {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            font-size: 16px;\n            color: #3b82f6;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"header\">\n        <div id=\"title\">SuperSearch</div>\n        <div id=\"subtitle\">Superconductor Composition Explorer</div>\n    </div>\n    \n    <div id=\"info\">\n        <div class=\"loading\">Loading materials...</div>\n        <div id=\"stats\"></div>\n    </div>\n    \n    <div id=\"canvas\"></div>\n    \n    <script>\n        const infoDiv = document.querySelector('#info .loading');\n        const statsDiv = document.getElementById('stats');\n        const container = document.getElementById('canvas');\n        \n        // Scene setup\n        const scene = new THREE.Scene();\n        scene.background = new THREE.Color(0x0a0e1a);\n        scene.fog = new THREE.Fog(0x0a0e1a, 50, 200);\n        \n        const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 1000);\n        camera.position.set(80, 60, 80);\n        \n        const renderer = new THREE.WebGLRenderer({ antialias: true });\n        renderer.setSize(window.innerWidth, window.innerHeight);\n        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n        container.appendChild(renderer.domElement);\n        \n        // Controls\n        const controls = new THREE.OrbitControls(camera, renderer.domElement);\n        controls.enableDamping = true;\n        controls.dampingFactor = 0.05;\n        controls.autoRotate = true;\n        controls.autoRotateSpeed = 0.3;\n        \n        // Lighting\n        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);\n        scene.add(ambientLight);\n        \n        const pointLight1 = new THREE.PointLight(0x3b82f6, 2, 300);\n        pointLight1.position.set(60, 60, 60);\n        scene.add(pointLight1);\n        \n        const pointLight2 = new THREE.PointLight(0x8b5cf6, 1.5, 300);\n        pointLight2.position.set(-60, -30, -60);\n        scene.add(pointLight2);\n        \n        // Load and render materials\n        fetch('data/analysis_results_fast.json')\n            .then(r => {\n                if (!r.ok) throw new Error(`HTTP ${r.status}`);\n                return r.json();\n            })\n            .then(data => {\n                const materials = data.materials;\n                infoDiv.textContent = `${materials.length.toLocaleString()} superconductor materials`;\n                \n                // Show stats\n                const clusters = new Set(materials.map(m => m.cluster)).size;\n                const avgTc = (materials.reduce((sum, m) => sum + m.tc, 0) / materials.length).toFixed(1);\n                statsDiv.innerHTML = `${clusters} clusters • Avg Tc: ${avgTc}K`;\n                \n                // Create geometry\n                const geometry = new THREE.BufferGeometry();\n                const positions = [];\n                const colors = [];\n                \n                // Calculate ranges\n                const xVals = materials.map(m => m.x);\n                const yVals = materials.map(m => m.y);\n                const tcVals = materials.map(m => m.tc);\n                \n                const xMin = Math.min(...xVals), xMax = Math.max(...xVals);\n                const yMin = Math.min(...yVals), yMax = Math.max(...yVals);\n                const tcMin = Math.min(...tcVals), tcMax = Math.max(...tcVals);\n                \n                materials.forEach(m => {\n                    // Scale to 3D space\n                    const x = ((m.x - xMin) / (xMax - xMin) - 0.5) * 60;\n                    const y = ((m.tc - tcMin) / (tcMax - tcMin) - 0.5) * 60;\n                    const z = ((m.y - yMin) / (yMax - yMin) - 0.5) * 60;\n                    \n                    positions.push(x, y, z);\n                    \n                    // Color by Tc (blue to pink gradient)\n                    const t = (m.tc - tcMin) / (tcMax - tcMin);\n                    const r = 0.2 + t * 0.8;\n                    const g = 0.3;\n                    const b = 0.9 - t * 0.5;\n                    colors.push(r, g, b);\n                });\n                \n                geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));\n                geometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));\n                \n                const material = new THREE.PointsMaterial({\n                    size: 0.8,\n                    vertexColors: true,\n                    transparent: true,\n                    opacity: 0.8,\n                    sizeAttenuation: true\n                });\n                \n                const points = new THREE.Points(geometry, material);\n                scene.add(points);\n                \n                console.log('✓ Rendered', materials.length, 'materials');\n            })\n            .catch(e => {\n                infoDiv.textContent = 'Error: ' + e.message;\n                infoDiv.style.color = '#ef4444';\n                console.error('Load error:', e);\n            });\n        \n        // Animation loop\n        function animate() {\n            requestAnimationFrame(animate);\n            controls.update();\n            renderer.render(scene, camera);\n        }\n        animate();\n        \n        // Handle window resize\n        window.addEventListener('resize', () => {\n            camera.aspect = window.innerWidth / window.innerHeight;\n            camera.updateProjectionMatrix();\n            renderer.setSize(window.innerWidth, window.innerHeight);\n        });\n    </script>\n</body>\n</html>\n","numLines":209,"startLine":1,"totalLines":209}}}
